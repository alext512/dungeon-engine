{
  "params": [
    "level_number"
  ],
  "commands": [
    {
      "type": "check_entity_var",
      "entity_id": "progress_controller",
      "name": "levels_completed",
      "op": "lt",
      "value": "$level_number",
      "then": [
        {
          "type": "set_entity_var",
          "entity_id": "progress_controller",
          "name": "levels_completed",
          "value": "$level_number",
          "persistent": true
        }
      ]
    }
  ]
}
