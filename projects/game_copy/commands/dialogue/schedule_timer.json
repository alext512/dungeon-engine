{
  "params": [
    "expected_revision"
  ],
  "commands": [
    {
      "type": "spawn_flow",
      "commands": [
        {
          "type": "wait_seconds",
          "seconds": "$self.dialogue_current_advance_seconds"
        },
        {
          "type": "if",
          "op": "eq",
          "then": [
            {
              "type": "run_project_command",
              "command_id": "commands/dialogue/advance_text",
              "entity_refs": {
                "instigator": "$self.dialogue_actor_id",
                "caller": "$self.dialogue_caller_id"
              }
            }
          ],
          "left": {
            "$entity_var": {
              "entity_id": "$self_id",
              "name": "dialogue_revision"
            }
          },
          "right": "$expected_revision"
        }
      ]
    }
  ]
}
