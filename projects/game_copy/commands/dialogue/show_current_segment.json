{
  "params": [],
  "commands": [
    {
      "type": "set_entity_var_length",
      "name": "dialogue_segment_count",
      "entity_id": "$self_id",
      "value": "$self.dialogue_definition.segments"
    },
    {
      "type": "if",
      "op": "gte",
      "then": [
        {
          "type": "run_project_command",
          "command_id": "commands/dialogue/close_current_dialogue"
        }
      ],
      "else": [
        {
          "type": "run_project_command",
          "command_id": "commands/dialogue/load_and_render_segment"
        }
      ],
      "left": {
        "$entity_var": {
          "entity_id": "$self_id",
          "name": "dialogue_segment_index"
        }
      },
      "right": "$self.dialogue_segment_count"
    }
  ]
}
