{
  "params": [],
  "commands": [
    {
      "type": "run_project_command",
      "command_id": "commands/dialogue/clear_choice_elements"
    },
    {
      "type": "set_entity_var",
      "name": "dialogue_selected_visible_choice_index",
      "entity_id": "$self_id",
      "value": {
        "$sum": [
          "$self.dialogue_choice_index",
          {
            "$product": [
              -1,
              "$self.dialogue_choice_scroll_offset"
            ]
          }
        ]
      }
    },
    {
      "type": "run_commands_for_collection",
      "value": {
        "$slice_collection": {
          "value": "$self.dialogue_current_segment_options",
          "start": "$self.dialogue_choice_scroll_offset",
          "count": "$self.layout.choice.visible_rows"
        }
      },
      "commands": [
        {
          "type": "set_entity_var",
          "name": "dialogue_render_option_element_id",
          "entity_id": "$self_id",
          "value": {
            "$collection_item": {
              "value": "$self.option_element_ids",
              "index": "$index",
              "default": ""
            }
          }
        },
        {
          "type": "set_entity_var",
          "name": "dialogue_render_option_row_y",
          "entity_id": "$self_id",
          "value": {
            "$sum": [
              "$self.layout.choice.base_y",
              {
                "$product": [
                  "$index",
                  "$self.layout.choice.row_height"
                ]
              }
            ]
          }
        },
        {
          "type": "set_entity_var",
          "name": "dialogue_render_option_prefix",
          "entity_id": "$self_id",
          "value": " "
        },
        {
          "type": "if",
          "op": "eq",
          "then": [
            {
              "type": "set_entity_var",
              "name": "dialogue_render_option_prefix",
              "entity_id": "$self_id",
              "value": ">"
            }
          ],
          "left": {
            "$entity_var": {
              "entity_id": "$self_id",
              "name": "dialogue_selected_visible_choice_index"
            }
          },
          "right": "$index"
        },
        {
          "type": "show_screen_text",
          "element_id": "$self.dialogue_render_option_element_id",
          "text": {
            "$join_text": [
              "$self.dialogue_render_option_prefix",
              "$item.text"
            ]
          },
          "x": "$self.choice_cursor_x",
          "y": "$self.dialogue_render_option_row_y",
          "layer": "$self.text_layer",
          "anchor": "topleft",
          "color": "$self.choice_text_color",
          "font_id": "$self.dialogue_font_id",
          "max_width": "$self.choice_width"
        }
      ]
    },
    {
      "type": "if",
      "op": "gt",
      "then": [
        {
          "type": "if",
          "op": "gt",
          "then": [
            {
              "type": "show_screen_text",
              "element_id": "$self.scroll_hint_element_id",
              "text": "^\n \nv",
              "x": "$self.layout.scroll_hint.more_up.x",
              "y": "$self.layout.scroll_hint.more_up.y",
              "layer": "$self.text_layer",
              "anchor": "topleft",
              "color": "$self.choice_text_color",
              "font_id": "$self.dialogue_font_id"
            }
          ],
          "else": [
            {
              "type": "show_screen_text",
              "element_id": "$self.scroll_hint_element_id",
              "text": "^",
              "x": "$self.layout.scroll_hint.more_up.x",
              "y": "$self.layout.scroll_hint.more_up.y",
              "layer": "$self.text_layer",
              "anchor": "topleft",
              "color": "$self.choice_text_color",
              "font_id": "$self.dialogue_font_id"
            }
          ],
          "left": {
            "$entity_var": {
              "entity_id": "$self_id",
              "name": "dialogue_current_option_count"
            }
          },
          "right": {
            "$sum": [
              "$self.dialogue_choice_scroll_offset",
              "$self.layout.choice.visible_rows"
            ]
          }
        }
      ],
      "else": [
        {
          "type": "if",
          "op": "gt",
          "then": [
            {
              "type": "show_screen_text",
              "element_id": "$self.scroll_hint_element_id",
              "text": "v",
              "x": "$self.layout.scroll_hint.more_down.x",
              "y": "$self.layout.scroll_hint.more_down.y",
              "layer": "$self.text_layer",
              "anchor": "topleft",
              "color": "$self.choice_text_color",
              "font_id": "$self.dialogue_font_id"
            }
          ],
          "left": {
            "$entity_var": {
              "entity_id": "$self_id",
              "name": "dialogue_current_option_count"
            }
          },
          "right": "$self.layout.choice.visible_rows"
        }
      ],
      "left": {
        "$entity_var": {
          "entity_id": "$self_id",
          "name": "dialogue_choice_scroll_offset"
        }
      },
      "right": 0
    }
  ]
}
