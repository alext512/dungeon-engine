{
  "kind": "restart_trigger",
  "tags": [
    "enter_trigger"
  ],
  "variables": {
    "blocks_movement": false
  },
  "visuals": [
    {
      "id": "main",
      "path": "assets/project/ui/empty.png",
      "frame_width": 1,
      "frame_height": 1,
      "frames": [
        0
      ]
    }
  ],
  "events": {
    "entered_by": {
      "enabled": true,
      "commands": [
        {
          "type": "run_event",
          "entity_id": "dialogue_controller",
          "event_id": "open_dialogue",
          "dialogue_path": "$dialogue_path",
          "dialogue_on_start": "$dialogue_on_start",
          "dialogue_on_end": "$dialogue_on_end",
          "segment_hooks": "$segment_hooks",
          "allow_cancel": "$allow_cancel",
          "actor_entity_id": "$actor_id",
          "caller_entity_id": "$self_id"
        }
      ]
    }
  },
  "render_order": 0
}
