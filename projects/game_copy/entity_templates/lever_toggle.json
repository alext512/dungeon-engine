{
  "kind": "lever",
  "variables": {
    "blocks_movement": true,
    "switch_value": 0,
    "trigger_only_once": "$trigger_only_once",
    "target_gate_id": "$target_gate_id",
    "target_index": "$target_index"
  },
  "visuals": [
    {
      "id": "main",
      "path": "assets/original/Lever.png",
      "frame_width": 16,
      "frame_height": 16,
      "frames": [
        0
      ]
    }
  ],
  "entity_commands": {
    "interact": {
      "enabled": true,
      "commands": [
        {
          "type": "if",
          "op": "eq",
          "then": [
            {
              "type": "set_entity_var",
              "entity_id": "$self_id",
              "name": "switch_value",
              "value": 1
            },
            {
              "type": "set_visual_frame",
              "entity_id": "$self_id",
              "frame": 3
            },
            {
              "type": "run_entity_command",
              "entity_id": "$self.target_gate_id",
              "command_id": "set_input_value",
              "index": "$self.target_index",
              "value": 1
            },
            {
              "type": "if",
              "op": "eq",
              "then": [
                {
                  "type": "set_entity_field",
                  "entity_id": "$self_id",
                  "field_name": "entity_commands_enabled",
                  "value": false
                }
              ],
              "left": {
                "$entity_var": {
                  "entity_id": "$self_id",
                  "name": "trigger_only_once"
                }
              },
              "right": true
            }
          ],
          "else": [
            {
              "type": "if",
              "op": "eq",
              "then": [
                {
                  "type": "set_entity_var",
                  "entity_id": "$self_id",
                  "name": "switch_value",
                  "value": 0
                },
                {
                  "type": "set_visual_frame",
                  "entity_id": "$self_id",
                  "frame": 0
                },
                {
                  "type": "run_entity_command",
                  "entity_id": "$self.target_gate_id",
                  "command_id": "set_input_value",
                  "index": "$self.target_index",
                  "value": 0
                }
              ],
              "left": {
                "$entity_var": {
                  "entity_id": "$self_id",
                  "name": "trigger_only_once"
                }
              },
              "right": false
            }
          ],
          "left": {
            "$entity_var": {
              "entity_id": "$self_id",
              "name": "switch_value"
            }
          },
          "right": 0
        }
      ]
    }
  },
  "render_order": 10
}
