{
  "kind": "button",
  "tags": [
    "enter_trigger",
    "leave_trigger"
  ],
  "variables": {
    "blocks_movement": false,
    "pressed": false,
    "single_use": "$single_use",
    "target_gate_id": "$target_gate_id",
    "target_index": "$target_index",
    "press_value": "$press_value",
    "release_value": "$release_value"
  },
  "visuals": [
    {
      "id": "main",
      "path": "assets/original/button.png",
      "frame_width": 16,
      "frame_height": 16,
      "frames": [
        0
      ]
    }
  ],
  "events": {
    "entered_by": {
      "enabled": true,
      "commands": [
        {
          "type": "check_entity_var",
          "entity_id": "$self_id",
          "name": "pressed",
          "op": "eq",
          "value": false,
          "then": [
            {
              "type": "set_entity_var",
              "entity_id": "$self_id",
              "name": "pressed",
              "value": true
            },
            {
              "type": "set_visual_frame",
              "entity_id": "$self_id",
              "frame": 1
            },
            {
              "type": "check_entity_var",
              "entity_id": "$self_id",
              "name": "target_gate_id",
              "op": "neq",
              "value": "",
              "then": [
                {
                  "type": "run_event",
                  "entity_id": "$self.target_gate_id",
                  "event_id": "set_input_value",
                  "index": "$self.target_index",
                  "value": "$self.press_value"
                }
              ]
            },
            {
              "type": "check_entity_var",
              "entity_id": "$self_id",
              "name": "single_use",
              "op": "eq",
              "value": true,
              "then": [
                {
                  "type": "set_entity_field",
                  "entity_id": "$self_id",
                  "field_name": "events_enabled",
                  "value": false
                }
              ]
            }
          ]
        }
      ]
    },
    "left_by": {
      "enabled": true,
      "commands": [
        {
          "type": "check_entity_var",
          "entity_id": "$self_id",
          "name": "single_use",
          "op": "eq",
          "value": false,
          "then": [
            {
              "type": "check_entity_var",
              "entity_id": "$self_id",
              "name": "pressed",
              "op": "eq",
              "value": true,
              "then": [
                {
                  "type": "set_entity_var",
                  "entity_id": "$self_id",
                  "name": "pressed",
                  "value": false
                },
                {
                  "type": "set_visual_frame",
                  "entity_id": "$self_id",
                  "frame": 0
                },
                {
                  "type": "check_entity_var",
                  "entity_id": "$self_id",
                  "name": "target_gate_id",
                  "op": "neq",
                  "value": "",
                  "then": [
                    {
                      "type": "run_event",
                      "entity_id": "$self.target_gate_id",
                      "event_id": "set_input_value",
                      "index": "$self.target_index",
                      "value": "$self.release_value"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  },
  "render_order": 0
}
