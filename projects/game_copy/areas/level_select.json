  "enter_commands": [
    {
      "type": "run_event",
      "entity_id": "progress_controller",
      "event_id": "refresh_level_select_entry"
    },
    {
      "type": "set_entity_grid_position",
      "entity_id": "player",
      "x": 1,
      "y": 2,
      "mode": "absolute"
    },
    {
      "type": "check_entity_var",
      "entity_id": "progress_controller",
      "name": "last_level_played",
      "op": "eq",
      "value": 2,
      "then": [
        {
          "type": "set_entity_grid_position",
          "entity_id": "player",
          "x": 1,
          "y": 3,
          "mode": "absolute"
        }
      ],
      "else": [
        {
          "type": "check_entity_var",
          "entity_id": "progress_controller",
          "name": "last_level_played",
          "op": "eq",
          "value": 3,
          "then": [
            {
