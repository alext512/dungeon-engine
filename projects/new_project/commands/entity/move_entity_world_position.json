/*
  NOTES

  Move a world entity through world-pixel space.
*/
{
  "inputs": {
    "entity_id": {
      "type": "entity_id"
    },
    "x": {
      "type": "float"
    },
    "y": {
      "type": "float"
    },
    "mode": {
      "type": "enum",
      "values": ["absolute", "relative"],
      "default": "absolute"
    },
    "duration": {
      "type": "float",
      "default": null
    },
    "frames_needed": {
      "type": "int",
      "default": null
    },
    "speed_px_per_second": {
      "type": "float",
      "default": null
    },
    "wait": {
      "type": "bool",
      "default": true
    },
    "persistent": {
      "type": "bool",
      "default": null
    }
  },
  "commands": [
    {
      "type": "move_entity_position",
      "entity_id": "$entity_id",
      "space": "world_pixel",
      "x": "$x",
      "y": "$y",
      "mode": "$mode",
      "duration": "$duration",
      "frames_needed": "$frames_needed",
      "speed_px_per_second": "$speed_px_per_second",
      "wait": "$wait",
      "persistent": "$persistent"
    }
  ]
}
