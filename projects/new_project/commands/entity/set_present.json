/*
  NOTES

  Set whether an entity participates in the current scene. Changing this may
  run occupant enter/leave hooks for the entity's cell.
*/
{
  "inputs": {
    "entity_id": {
      "type": "entity_id"
    },
    "present": {
      "type": "bool"
    },
    "persistent": {
      "type": "bool",
      "default": null
    }
  },
  "commands": [
    {
      "type": "set_entity_field",
      "entity_id": "$entity_id",
      "field_name": "present",
      "value": "$present",
      "persistent": "$persistent"
    }
  ]
}
