/*
  NOTES

  Set whether an entity is drawn and considered visible.
*/
{
  "inputs": {
    "entity_id": {
      "type": "entity_id"
    },
    "visible": {
      "type": "bool"
    },
    "persistent": {
      "type": "bool",
      "default": null
    }
  },
  "commands": [
    {
      "type": "set_entity_field",
      "entity_id": "$entity_id",
      "field_name": "visible",
      "value": "$visible",
      "persistent": "$persistent"
    }
  ]
}
