/*
  NOTES

  Follow one explicit entity with the active camera.
*/
{
  "inputs": {
    "entity_id": {
      "type": "entity_id"
    },
    "offset_x": {
      "type": "float",
      "default": 0
    },
    "offset_y": {
      "type": "float",
      "default": 0
    }
  },
  "commands": [
    {
      "type": "set_camera_policy",
      "follow": {
        "mode": "entity",
        "entity_id": "$entity_id",
        "offset_x": "$offset_x",
        "offset_y": "$offset_y"
      }
    }
  ]
}
