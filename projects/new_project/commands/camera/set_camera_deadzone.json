/*
  NOTES

  Set the viewport-space camera follow deadzone.
*/
{
  "inputs": {
    "x": {
      "type": "float"
    },
    "y": {
      "type": "float"
    },
    "width": {
      "type": "float"
    },
    "height": {
      "type": "float"
    },
    "space": {
      "type": "enum",
      "values": ["viewport_pixel", "viewport_grid"],
      "default": "viewport_pixel"
    }
  },
  "commands": [
    {
      "type": "set_camera_policy",
      "deadzone": {
        "x": "$x",
        "y": "$y",
        "width": "$width",
        "height": "$height",
        "space": "$space"
      }
    }
  ]
}
