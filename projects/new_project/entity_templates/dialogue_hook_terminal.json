/*
  NOTES

  Interactable sample terminal that opens a dialogue with caller-supplied
  segment hooks. The hook overrides the dialogue option's inline command.
*/
{
  "kind": "dialogue_hook_terminal",
  "solid": false,
  "interactable": true,
  "interaction_priority": 15,
  "render_order": 10,
  "y_sort": true,
  "variables": {
    "last_hook_choice": ""
  },
  "visuals": [
    {
      "id": "main",
      "path": "assets/Lever.png",
      "frame_width": 16,
      "frame_height": 16,
      "frames": [0],
      "visible": true
    }
  ],
  "entity_commands": {
    "interact": [
      {
        "type": "open_dialogue_session",
        "dialogue_path": "dialogues/system/sample_hook_choice.json",
        "allow_cancel": true,
        "entity_refs": {
          "caller": "$self_id",
          "instigator": "$ref_ids.instigator"
        },
        "segment_hooks": [
          {
            "option_commands_by_id": {
              "mark_hook": [
                {
                  "type": "set_entity_var",
                  "entity_id": "$ref_ids.caller",
                  "name": "last_hook_choice",
                  "value": "hook"
                }
              ]
            }
          }
        ]
      }
    ]
  }
}
