{
  "kind": "system",
  "space": "screen",
  "visible": true,
  "parameter_specs": {
    "sprite_path": {
      "type": "asset_path",
      "required": true,
      "asset_kind": "image"
    },
    "frame_width": {
      "type": "int",
      "required": true,
      "min": 1
    },
    "frame_height": {
      "type": "int",
      "required": true,
      "min": 1
    },
    "frames": {
      "type": "array",
      "required": true,
      "items": {
        "type": "int",
        "min": 0
      }
    },
    "animation_fps": {
      "type": "number",
      "required": true,
      "min": 0
    }
  },
  "visuals": [
    {
      "id": "main",
      "path": "$sprite_path",
      "frame_width": "$frame_width",
      "frame_height": "$frame_height",
      "frames": "$frames",
      "animation_fps": "$animation_fps",
      "animate_when_moving": false
    }
  ],
  "render_order": 0,
  "y_sort": false
}
