{
  "kind": "area_transition",
  "solid": false,
  "visible": false,
  "interactable": false,
  "parameters": {
    "target_area": "areas/start",
    "destination_entity_id": "starting_position",
    "allowed_instigator_kinds": [
      "player"
    ]
  },
  "parameter_specs": {
    "target_area": {
      "type": "area_id",
      "required": true
    },
    "destination_entity_id": {
      "type": "entity_id",
      "required": true,
      "of": "target_area",
      "scope": "area",
      "space": "world"
    },
    "allowed_instigator_kinds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "entity_commands": {
    "on_occupant_enter": [
      {
        "type": "change_area",
        "area_id": "$target_area",
        "destination_entity_id": "$destination_entity_id",
        "allowed_instigator_kinds": "$allowed_instigator_kinds",
        "transfer_entity_ids": [
          "$instigator_id"
        ],
        "camera_follow": {
          "mode": "entity",
          "entity_id": "$instigator_id"
        }
      }
    ]
  }
}
