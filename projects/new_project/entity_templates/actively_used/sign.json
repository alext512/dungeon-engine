/*
  NOTES

  Simple interactable sign. It owns one named dialogue entry and opens the
  currently active one when the player interacts. Instances can still override
  the dialogue_path parameter to reuse the same template with different text.
*/
{
  "kind": "sign",
  "solid": true,
  "interactable": true,
  "interaction_priority": 10,
  "render_order": 10,
  "y_sort": true,
  "parameters": {
    "dialogue_path": "dialogues/signs/simple_sign.json"
  },
  "parameter_specs": {
    "dialogue_path": {
      "type": "dialogue_path",
      "required": true
    }
  },
  "dialogues": {
    "starting_dialogue": {
      "dialogue_path": "$dialogue_path"
    }
  },
  "variables": {
    "active_dialogue": "starting_dialogue"
  },
  "visuals": [
    {
      "id": "main",
      "path": "assets/used_tilesets_sprites/overworld_expanded.png",
      "frame_width": 16,
      "frame_height": 16,
      "frames": [3],
      "visible": true
    }
  ],
  "entity_commands": {
    "interact": [
      {
        "type": "open_entity_dialogue",
        "entity_id": "$self_id",
        "allow_cancel": true
      }
    ]
  }
}
