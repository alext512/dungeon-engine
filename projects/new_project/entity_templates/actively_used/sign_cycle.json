/*
  NOTES

  Sign template that owns multiple named dialogues. It opens whichever named
  dialogue is currently active, then switches itself to the repeat entry so
  later interactions show the shorter follow-up line.
*/
{
  "kind": "sign",
  "solid": true,
  "interactable": true,
  "interaction_priority": 10,
  "render_order": 10,
  "y_sort": true,
  "dialogues": {
    "intro": {
      "dialogue_path": "dialogues/signs/cycle_intro.json"
    },
    "repeat": {
      "dialogue_definition": {
        "segments": [
          {
            "type": "text",
            "text": "\"The warning is still drying into the wood.\""
          }
        ]
      }
    }
  },
  "variables": {
    "active_dialogue": "intro"
  },
  "visuals": [
    {
      "id": "main",
      "path": "assets/used_tilesets_sprites/overworld_expanded.png",
      "frame_width": 16,
      "frame_height": 16,
      "frames": [3],
      "visible": true
    }
  ],
  "entity_commands": {
    "interact": [
      {
        "type": "open_entity_dialogue",
        "entity_id": "$self_id",
        "allow_cancel": true
      },
      {
        "type": "set_entity_active_dialogue",
        "entity_id": "$self_id",
        "dialogue_id": "repeat",
        "persistent": true
      }
    ]
  }
}
