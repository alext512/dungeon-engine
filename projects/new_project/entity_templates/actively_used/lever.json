{
  "kind": "lever",
  "solid": false,
  "interactable": true,
  "interaction_priority": 10,
  "render_order": 10,
  "y_sort": true,
  "visuals": [
    {
      "id": "main",
      "path": "assets/Lever.png",
      "frame_width": 16,
      "frame_height": 16,
      "frames": [0, 1, 2, 3],
      "animations": {
        "toggle_on": { "frames": [0, 1, 2, 3] },
        "toggle_off": { "frames": [3, 2, 1, 0] }
      },
      "visible": true
    }
  ],
  "parameters": {
    "toggleable": true,
    "target_entity_id": "",
    "target_activate_command_id": "contribute_on",
    "target_deactivate_command_id": "contribute_off"
  },
  "parameter_specs": {
    "toggleable": {
      "type": "bool"
    },
    "target_entity_id": {
      "type": "entity_id",
      "scope": "area",
      "space": "world"
    },
    "target_activate_command_id": {
      "type": "entity_command_id",
      "of": "target_entity_id"
    },
    "target_deactivate_command_id": {
      "type": "entity_command_id",
      "of": "target_entity_id"
    }
  },
  "variables": {
    "active": false
  },
  "entity_commands": {
    "interact": [
      {
        "type": "if",
        "left": "$self.active",
        "op": "eq",
        "right": false,
        "then": [
          {
            "type": "set_entity_fields",
            "entity_id": "$self_id",
            "set": {
              "variables": {
                "active": true
              },
              "visuals": {
                "main": {
                  "current_frame": 0
                }
              }
            }
          },
          {
            "type": "play_animation",
            "entity_id": "$self_id",
            "visual_id": "main",
            "animation": "toggle_on",
            "wait": false
          },
          {
            "type": "run_entity_command",
            "entity_id": "$target_entity_id",
            "command_id": "$target_activate_command_id"
          }
        ],
        "else": [
          {
            "type": "if",
            "left": "$toggleable",
            "op": "eq",
            "right": true,
            "then": [
              {
                "type": "set_entity_fields",
                "entity_id": "$self_id",
                "set": {
                  "variables": {
                    "active": false
                  },
                  "visuals": {
                    "main": {
                      "current_frame": 3
                    }
                  }
                }
              },
              {
                "type": "play_animation",
                "entity_id": "$self_id",
                "visual_id": "main",
                "animation": "toggle_off",
                "wait": false
              },
              {
                "type": "run_entity_command",
                "entity_id": "$target_entity_id",
                "command_id": "$target_deactivate_command_id"
              }
            ]
          }
        ]
      }
    ]
  }
}
