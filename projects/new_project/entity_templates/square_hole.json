{
  "kind": "square_hole",
  "solid": false,
  "interactable": false,
  "render_order": 5,
  "y_sort": false,
  "visuals": [
    {
      "id": "empty",
      "path": "assets/square_Hole.png",
      "frame_width": 16,
      "frame_height": 16,
      "frames": [0],
      "visible": true
    },
    {
      "id": "fill",
      "path": "assets/Box_Dissapearing.png",
      "frame_width": 16,
      "frame_height": 16,
      "frames": [5, 6, 7, 8],
      "visible": false
    }
  ],
  "parameters": {
    "group_target_entity_id": "",
    "group_fill_command_id": "contribute_on",
    "filled_target_entity_id": "",
    "filled_command_id": ""
  },
  "variables": {
    "filled": false
  },
  "entity_commands": {
    "on_occupant_enter": {
      "enabled": true,
      "commands": [
        {
          "type": "if",
          "left": "$self.filled",
          "op": "eq",
          "right": false,
          "then": [
            {
              "type": "run_entity_command",
              "entity_id": "$ref_ids.instigator",
              "command_id": "fall_into_square_hole",
              "hole_id": "$self_id"
            }
          ]
        }
      ]
    },
    "fill_now": {
      "enabled": true,
      "commands": [
        {
          "type": "if",
          "left": "$self.filled",
          "op": "eq",
          "right": false,
          "then": [
            {
              "type": "set_entity_fields",
              "entity_id": "$self_id",
              "set": {
                "variables": {
                  "filled": true
                },
                "visuals": {
                  "empty": {
                    "visible": false
                  },
                  "fill": {
                    "visible": true,
                    "current_frame": 5
                  }
                }
              }
            },
            {
              "type": "play_animation",
              "entity_id": "$self_id",
              "visual_id": "fill",
              "frame_sequence": [5, 6, 7, 8],
              "hold_last_frame": true,
              "wait": false
            },
            {
              "type": "run_entity_command",
              "entity_id": "$group_target_entity_id",
              "command_id": "$group_fill_command_id"
            },
            {
              "type": "run_entity_command",
              "entity_id": "$filled_target_entity_id",
              "command_id": "$filled_command_id"
            }
          ]
        }
      ]
    }
  }
}
