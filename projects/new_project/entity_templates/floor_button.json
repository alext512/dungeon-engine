{
  "kind": "floor_button",
  "solid": false,
  "interactable": false,
  "render_order": 5,
  "y_sort": false,
  "visuals": [
    {
      "id": "main",
      "path": "assets/button.png",
      "frame_width": 16,
      "frame_height": 16,
      "frames": [0, 1],
      "visible": true
    }
  ],
  "parameters": {
    "latching": false,
    "target_entity_id": "",
    "target_press_command_id": "contribute_on",
    "target_release_command_id": "contribute_off"
  },
  "parameter_specs": {
    "latching": {
      "type": "bool"
    },
    "target_entity_id": {
      "type": "entity_id",
      "scope": "area",
      "space": "world"
    },
    "target_press_command_id": {
      "type": "entity_command_id",
      "of": "target_entity_id"
    },
    "target_release_command_id": {
      "type": "entity_command_id",
      "of": "target_entity_id"
    }
  },
  "variables": {
    "pressed": false
  },
  "entity_commands": {
    "on_occupant_enter": [
      {
        "type": "if",
        "left": "$self.pressed",
        "op": "eq",
        "right": false,
        "then": [
          {
            "type": "set_entity_fields",
            "entity_id": "$self_id",
            "set": {
              "variables": {
                "pressed": true
              },
              "visuals": {
                "main": {
                  "current_frame": 1
                }
              }
            }
          },
          {
            "type": "run_entity_command",
            "entity_id": "$target_entity_id",
            "command_id": "$target_press_command_id"
          }
        ]
      }
    ],
    "on_occupant_leave": [
      {
        "type": "if",
        "left": "$self.pressed",
        "op": "eq",
        "right": true,
        "then": [
          {
            "type": "if",
            "left": "$latching",
            "op": "eq",
            "right": false,
            "then": [
              {
                "type": "if",
                "left": {
                  "$any_in_collection": {
                    "value": {
                      "$entities_at": {
                        "x": "$from_x",
                        "y": "$from_y",
                        "exclude_entity_id": "$self_id",
                        "select": {
                          "fields": ["entity_id"]
                        }
                      }
                    },
                    "field": "entity_id",
                    "op": "neq",
                    "match": ""
                  }
                },
                "op": "eq",
                "right": false,
                "then": [
                  {
                    "type": "set_entity_fields",
                    "entity_id": "$self_id",
                    "set": {
                      "variables": {
                        "pressed": false
                      },
                      "visuals": {
                        "main": {
                          "current_frame": 0
                        }
                      }
                    }
                  },
                  {
                    "type": "run_entity_command",
                    "entity_id": "$target_entity_id",
                    "command_id": "$target_release_command_id"
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
