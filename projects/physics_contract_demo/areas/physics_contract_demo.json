      "grid_x": 8,
      "grid_y": 2
    },
    {
      "id": "copper_door",
      "template": "entity_templates/locked_door_contract",
      "parameters": {
        "required_item_id": "items/copper_key",
        "locked_dialogue_path": "dialogues/showcase/door_locked.json",
        "success_dialogue_path": "dialogues/showcase/door_unlocked.json",
        "open_dialogue_path": "dialogues/showcase/door_open.json"
      },
      "grid_x": 9,
      "grid_y": 2
    },
    {
      "id": "behind_door_sign",
      "template": "entity_templates/sign_contract",
