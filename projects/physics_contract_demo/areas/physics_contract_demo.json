    {
      "id": "dialogue_terminal",
      "template": "entity_templates/dialogue_terminal_contract",
      "parameters": {
        "target_indicator_id": "occupancy_indicator",
        "dialogue_path": "dialogues/showcase/dialogue_runtime_menu.json"
      },
      "grid_x": 5,
      "grid_y": 4
    },
    {
      "id": "dialogue_terminal_panel",
      "template": "entity_templates/dialogue_terminal_contract",
