{
  "kind": "keeper",
  "solid": true,
  "interactable": true,
  "interaction_priority": 10,
  "render_order": 10,
  "variables": {
    "gave_item": false,
    "item_id": "$item_id",
    "quantity": "$quantity",
    "success_dialogue_path": "$success_dialogue_path",
    "full_dialogue_path": "$full_dialogue_path",
    "repeat_dialogue_path": "$repeat_dialogue_path"
  },
  "visuals": [
    {
      "id": "main",
      "path": "assets/project/sprites/sign.png",
      "frame_width": 16,
      "frame_height": 16,
      "frames": [
        0
      ]
    }
  ],
  "entity_commands": {
    "interact": {
      "enabled": true,
      "commands": [
        {
          "type": "if",
          "left": "$self.gave_item",
          "op": "eq",
          "right": false,
          "then": [
            {
              "type": "add_inventory_item",
              "entity_id": "$ref_ids.instigator",
              "item_id": "$self.item_id",
              "quantity": "$self.quantity",
              "quantity_mode": "atomic",
              "result_var_name": "last_inventory_result"
            },
            {
              "type": "if",
              "left": "$self.last_inventory_result.changed_quantity",
              "op": "gt",
              "right": 0,
              "then": [
                {
                  "type": "set_entity_var",
                  "entity_id": "$self_id",
                  "name": "gave_item",
                  "value": true
                },
                {
                  "type": "open_dialogue_session",
                  "dialogue_path": "$self.success_dialogue_path",
                  "dialogue_on_start": [],
                  "dialogue_on_end": [],
                  "segment_hooks": [],
                  "allow_cancel": false,
                  "entity_refs": {
                    "instigator": "$ref_ids.instigator",
                    "caller": "$self_id"
                  }
                }
              ],
              "else": [
                {
                  "type": "open_dialogue_session",
                  "dialogue_path": "$self.full_dialogue_path",
                  "dialogue_on_start": [],
                  "dialogue_on_end": [],
                  "segment_hooks": [],
                  "allow_cancel": false,
                  "entity_refs": {
                    "instigator": "$ref_ids.instigator",
                    "caller": "$self_id"
                  }
                }
              ]
            }
          ],
          "else": [
            {
              "type": "open_dialogue_session",
              "dialogue_path": "$self.repeat_dialogue_path",
              "dialogue_on_start": [],
              "dialogue_on_end": [],
              "segment_hooks": [],
              "allow_cancel": false,
              "entity_refs": {
                "instigator": "$ref_ids.instigator",
                "caller": "$self_id"
              }
            }
          ]
        }
      ]
    }
  }
}
