{
  "kind": "terminal",
  "solid": true,
  "interactable": true,
  "interaction_priority": 10,
  "variables": {
    "target_indicator_id": "$target_indicator_id",
    "dialogue_path": "$dialogue_path"
  },
  "visuals": [
    {
      "id": "main",
      "path": "assets/project/sprites/sign.png",
      "frame_width": 16,
      "frame_height": 16,
      "frames": [
        0
      ]
    }
  ],
  "entity_commands": {
    "interact": {
      "enabled": true,
      "commands": [
        {
          "type": "open_dialogue_session",
          "dialogue_path": "$self.dialogue_path",
          "dialogue_on_start": [],
          "dialogue_on_end": [],
          "segment_hooks": [],
          "allow_cancel": true,
          "entity_refs": {
            "instigator": "$ref_ids.instigator",
            "caller": "$self_id"
          }
        }
      ]
    }
  },
  "render_order": 10
}
