{
  "params": [
    "direction",
    "frames_needed"
  ],
  "commands": [
    {
      "type": "set_entity_var",
      "entity_id": "$self_id",
      "name": "push_offset",
      "value": {
        "$collection_item": {
          "value": {
            "up": { "x": 0, "y": -1 },
            "down": { "x": 0, "y": 1 },
            "left": { "x": -1, "y": 0 },
            "right": { "x": 1, "y": 0 }
          },
          "key": "$direction",
          "default": { "x": 0, "y": 0 }
        }
      }
    },
    {
      "type": "set_entity_grid_position",
      "entity_id": "$self_id",
      "x": "$self.push_offset.x",
      "y": "$self.push_offset.y",
      "mode": "relative"
    },
    {
      "type": "play_audio",
      "path": "assets/project/sfx/push.wav"
    },
    {
      "type": "move_entity_world_position",
      "entity_id": "$self_id",
      "x": {
        "$product": [
          "$self.push_offset.x",
          "$area.tile_size"
        ]
      },
      "y": {
        "$product": [
          "$self.push_offset.y",
          "$area.tile_size"
        ]
      },
      "mode": "relative",
      "frames_needed": "$frames_needed",
      "wait": false
    }
  ]
}
