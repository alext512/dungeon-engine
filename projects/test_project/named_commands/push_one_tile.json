{
  "params": [
    "direction",
    "frames_needed"
  ],
  "commands": [
    {
      "type": "set_entity_var",
      "entity_id": "$self_id",
      "name": "push_attempt_info",
      "value": {
        "$facing_state": {
          "entity_id": "$self_id",
          "direction": "$direction"
        }
      }
    },
    {
      "type": "set_entity_var",
      "entity_id": "$self_id",
      "name": "push_attempt_state",
      "value": "$self.push_attempt_info.state"
    },
    {
      "type": "check_entity_var",
      "entity_id": "$self_id",
      "name": "push_attempt_state",
      "op": "eq",
      "value": "free",
      "then": [
        {
          "type": "play_audio",
          "path": "assets/project/sfx/push.wav"
        },
        {
          "type": "move_entity_one_tile",
          "entity_id": "$self_id",
          "direction": "$direction",
          "frames_needed": "$frames_needed",
          "allow_push": false,
          "wait": false
        }
      ]
    }
  ]
}
