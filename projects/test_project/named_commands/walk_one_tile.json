{
  "params": [
    "direction",
    "phase_a_frames",
    "phase_b_frames",
    "idle_frame",
    "frames_per_sprite_change",
    "frames_needed"
  ],
  "commands": [
    {
      "type": "check_entity_var",
      "entity_id": "$self_id",
      "name": "walk_phase",
      "op": "eq",
      "value": 1,
      "then": [
        {
          "type": "play_animation",
          "entity_id": "$self_id",
          "frame_sequence": "$phase_b_frames",
          "frames_per_sprite_change": "$frames_per_sprite_change",
          "wait": false
        },
        {
          "type": "set_entity_var",
          "entity_id": "$self_id",
          "name": "walk_phase",
          "value": 0
        }
      ],
      "else": [
        {
          "type": "play_animation",
          "entity_id": "$self_id",
          "frame_sequence": "$phase_a_frames",
          "frames_per_sprite_change": "$frames_per_sprite_change",
          "wait": false
        },
        {
          "type": "set_entity_var",
          "entity_id": "$self_id",
          "name": "walk_phase",
          "value": 1
        }
      ]
    },
    {
      "type": "run_commands",
      "commands": [
        {
          "type": "move_entity_one_tile",
          "entity_id": "$self_id",
          "direction": "$direction",
          "frames_needed": "$frames_needed",
          "allow_push": false
        },
        {
          "type": "stop_animation",
          "entity_id": "$self_id",
          "reset_to_default": false
        },
        {
          "type": "set_visual_frame",
          "entity_id": "$self_id",
          "frame": "$idle_frame"
        }
      ]
    }
  ]
}
