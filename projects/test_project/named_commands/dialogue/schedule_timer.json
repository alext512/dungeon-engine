{
  "params": [
    "expected_revision"
  ],
  "commands": [
    {
      "type": "run_detached_commands",
      "commands": [
        {
          "type": "wait_seconds",
          "seconds": "$self.dialogue_current_advance_seconds"
        },
        {
          "type": "check_entity_var",
          "entity_id": "$self_id",
          "name": "dialogue_revision",
          "op": "eq",
          "value": "$expected_revision",
          "then": [
            {
              "type": "run_named_command",
              "command_id": "dialogue/advance_text",
              "actor_entity_id": "$self.dialogue_actor_id",
              "caller_entity_id": "$self.dialogue_caller_id"
            }
          ]
        }
      ]
    }
  ]
}
