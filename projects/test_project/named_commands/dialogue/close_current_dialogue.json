{
  "params": [],
  "commands": [
    {
      "type": "increment_entity_var",
      "entity_id": "$self_id",
      "name": "dialogue_revision",
      "amount": 1
    },
    {
      "type": "set_entity_var",
      "entity_id": "$self_id",
      "name": "dialogue_pending_on_end",
      "value": "$self.dialogue_on_end"
    },
    {
      "type": "set_entity_var",
      "entity_id": "$self_id",
      "name": "dialogue_pending_actor_id",
      "value": "$self.dialogue_actor_id"
    },
    {
      "type": "set_entity_var",
      "entity_id": "$self_id",
      "name": "dialogue_pending_caller_id",
      "value": "$self.dialogue_caller_id"
    },
    {
      "type": "set_entity_var_length",
      "name": "dialogue_stack_count",
      "entity_id": "$self_id",
      "value": "$self.dialogue_state_stack"
    },
    {
      "type": "check_entity_var",
      "name": "dialogue_stack_count",
      "entity_id": "$self_id",
      "op": "gt",
      "value": 0,
      "then": [
        {
          "type": "pop_entity_var",
          "entity_id": "$self_id",
          "name": "dialogue_state_stack",
          "store_var": "dialogue_restored_state",
          "default": {}
        },
        {
          "type": "run_named_command",
          "command_id": "dialogue/restore_snapshot"
        },
        {
          "type": "run_sequence",
          "commands": "$self.dialogue_pending_on_end",
          "actor_entity_id": "$self.dialogue_pending_actor_id",
          "caller_entity_id": "$self.dialogue_pending_caller_id"
        },
        {
          "type": "set_entity_var",
          "entity_id": "$self_id",
          "name": "dialogue_pending_on_end",
          "value": []
        },
        {
          "type": "set_entity_var",
          "entity_id": "$self_id",
          "name": "dialogue_pending_actor_id",
          "value": null
        },
        {
          "type": "set_entity_var",
          "entity_id": "$self_id",
          "name": "dialogue_pending_caller_id",
          "value": null
        }
      ],
      "else": [
        {
          "type": "run_named_command",
          "command_id": "dialogue/clear_ui"
        },
        {
          "type": "set_entity_var",
          "entity_id": "$self_id",
          "name": "dialogue_open",
          "value": false
        },
        {
          "type": "set_entity_var",
          "entity_id": "$self_id",
          "name": "dialogue_path",
          "value": ""
        },
        {
          "type": "set_entity_var",
          "entity_id": "$self_id",
          "name": "dialogue_definition",
          "value": {}
        },
        {
          "type": "set_entity_var",
          "entity_id": "$self_id",
          "name": "dialogue_on_end",
          "value": []
        },
        {
          "type": "set_entity_var",
          "entity_id": "$self_id",
          "name": "dialogue_segment_hooks",
          "value": []
        },
        {
          "type": "set_entity_var",
          "entity_id": "$self_id",
          "name": "dialogue_allow_cancel",
          "value": false
        },
        {
          "type": "set_entity_var",
          "entity_id": "$self_id",
          "name": "dialogue_actor_id",
          "value": null
        },
        {
          "type": "set_entity_var",
          "entity_id": "$self_id",
          "name": "dialogue_caller_id",
          "value": null
        },
        {
          "type": "set_entity_var",
          "entity_id": "$self_id",
          "name": "dialogue_segment_index",
          "value": 0
        },
        {
          "type": "set_entity_var",
          "entity_id": "$self_id",
          "name": "dialogue_source_page_index",
          "value": 0
        },
        {
          "type": "set_entity_var",
          "entity_id": "$self_id",
          "name": "dialogue_text_line_offset",
          "value": 0
        },
        {
          "type": "set_entity_var",
          "entity_id": "$self_id",
          "name": "dialogue_choice_index",
          "value": 0
        },
        {
          "type": "set_entity_var",
          "entity_id": "$self_id",
          "name": "dialogue_current_speaker_id",
          "value": null
        },
        {
          "type": "pop_input_routes"
        },
        {
          "type": "run_sequence",
          "commands": "$self.dialogue_pending_on_end",
          "actor_entity_id": "$self.dialogue_pending_actor_id",
          "caller_entity_id": "$self.dialogue_pending_caller_id"
        },
        {
          "type": "set_entity_var",
          "entity_id": "$self_id",
          "name": "dialogue_pending_on_end",
          "value": []
        },
        {
          "type": "set_entity_var",
          "entity_id": "$self_id",
          "name": "dialogue_pending_actor_id",
          "value": null
        },
        {
          "type": "set_entity_var",
          "entity_id": "$self_id",
          "name": "dialogue_pending_caller_id",
          "value": null
        }
      ]
    }
  ]
}

