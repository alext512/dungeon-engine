{
  "kind": "system",
  "space": "screen",
  "visible": false,
  "render_order": 99,
  "input_map": {
    "menu": "open_pause_menu"
  },
  "entity_commands": {
    "open_pause_menu": {
      "enabled": true,
      "commands": [
        {
          "type": "run_entity_command",
          "entity_id": "dialogue_controller",
          "command_id": "open_dialogue",
          "dialogue_path": "dialogues/system/pause_menu.json",
          "dialogue_on_start": [
            {
              "type": "set_entity_var",
              "entity_id": "$self_id",
              "name": "pending_pause_menu_action",
              "value": ""
            }
          ],
          "dialogue_on_end": [
            {
              "type": "if",
              "op": "eq",
              "then": [
                {
                  "type": "load_game"
                }
              ],
              "left": {
                "$entity_var": {
                  "entity_id": "$self_id",
                  "name": "pending_pause_menu_action"
                }
              },
              "right": "load"
            },
            {
              "type": "if",
              "op": "eq",
              "then": [
                {
                  "type": "quit_game"
                }
              ],
              "left": {
                "$entity_var": {
                  "entity_id": "$self_id",
                  "name": "pending_pause_menu_action"
                }
              },
              "right": "exit"
            },
            {
              "type": "set_entity_var",
              "entity_id": "$self_id",
              "name": "pending_pause_menu_action",
              "value": ""
            }
          ],
          "segment_hooks": [
            {
              "option_commands_by_id": {
                "continue": [],
                "load": [
                  {
                    "type": "set_entity_var",
                    "entity_id": "$self_id",
                    "name": "pending_pause_menu_action",
                    "value": "load"
                  }
                ],
                "exit": [
                  {
                    "type": "set_entity_var",
                    "entity_id": "$self_id",
                    "name": "pending_pause_menu_action",
                    "value": "exit"
                  }
                ]
              }
            }
          ],
          "allow_cancel": true,
          "entity_refs": {
            "caller": "$self_id"
          }
        }
      ]
    }
  },
  "y_sort": false
}
