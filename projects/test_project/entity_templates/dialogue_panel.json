{
  "kind": "system",
  "space": "screen",
  "solid": false,
  "visible": false,
  "layer": 100,
  "input_map": {
    "interact": "interact",
    "menu": "menu",
    "move_up": "move_up",
    "move_down": "move_down"
  },
  "variables": {
    "panel_element_id": "dialogue_panel",
    "portrait_element_id": "dialogue_portrait",
    "text_element_id": "dialogue_text",
    "cursor_element_id": "dialogue_cursor",
    "option_element_ids": [
      "dialogue_option_0",
      "dialogue_option_1",
      "dialogue_option_2",
      "dialogue_option_3"
    ],
    "option_rows_y": [154, 164, 174, 184],
    "panel_path": "assets/project/ui/dialogue_panel.png",
    "panel_x": 0,
    "panel_y": 148,
    "panel_frame_width": 256,
    "panel_frame_height": 44,
    "portrait_x": 8,
    "portrait_y": 154,
    "plain_text_box_x": 8,
    "plain_text_box_y": 154,
    "plain_text_box_width": 240,
    "plain_choice_text_x": 16,
    "plain_choice_width": 232,
    "plain_choice_cursor_x": 8,
    "portrait_text_box_x": 56,
    "portrait_text_box_y": 154,
    "portrait_text_box_width": 192,
    "portrait_choice_text_x": 64,
    "portrait_choice_width": 180,
    "portrait_choice_cursor_x": 56,
    "ui_layer": 100,
    "text_layer": 101,
    "default_font_id": "pixelbet",
    "default_max_lines": 3,
    "default_text_color": [245, 232, 190],
    "choice_text_color": [238, 242, 248],
    "choice_cursor_color": [245, 232, 190],
    "default_portrait_frame_width": 16,
    "default_portrait_frame_height": 16,
    "dialogue_open": false,
    "dialogue_state_stack": [],
    "dialogue_pending_on_end": [],
    "dialogue_pending_actor_id": null,
    "dialogue_pending_caller_id": null,
    "dialogue_restored_state": {},
    "dialogue_path": "",
    "dialogue_definition": {},
    "dialogue_on_end": [],
    "dialogue_segment_hooks": [],
    "dialogue_allow_cancel": false,
    "dialogue_actor_id": null,
    "dialogue_caller_id": null,
    "dialogue_segment_index": 0,
    "dialogue_source_page_index": 0,
    "dialogue_text_line_offset": 0,
    "dialogue_choice_index": 0,
    "dialogue_current_speaker_id": null,
    "dialogue_revision": 0
  },
  "visuals": [],
  "events": {
    "interact": {
      "enabled": true,
      "commands": [
        {
          "type": "run_named_command",
          "command_id": "dialogue/interact"
        }
      ]
    },
    "menu": {
      "enabled": true,
      "commands": [
        {
          "type": "run_named_command",
          "command_id": "dialogue/cancel"
        }
      ]
    },
    "move_up": {
      "enabled": true,
      "commands": [
        {
          "type": "run_named_command",
          "command_id": "dialogue/move_selection",
          "delta": -1
        }
      ]
    },
    "move_down": {
      "enabled": true,
      "commands": [
        {
          "type": "run_named_command",
          "command_id": "dialogue/move_selection",
          "delta": 1
        }
      ]
    },
    "open_dialogue": {
      "enabled": true,
      "commands": [
        {
          "type": "run_named_command",
          "command_id": "dialogue/open",
          "dialogue_path": "$dialogue_path",
          "dialogue_on_start": "$dialogue_on_start",
          "dialogue_on_end": "$dialogue_on_end",
          "segment_hooks": "$segment_hooks",
          "allow_cancel": "$allow_cancel",
          "actor_entity_id": "$actor_entity_id",
          "caller_entity_id": "$caller_entity_id"
        }
      ]
    }
  }
}
