{
  "kind": "save_point",
  "variables": {
    "blocks_movement": true
  },
  "visuals": [
    {
      "id": "main",
      "path": "assets/project/sprites/sign.png",
      "frame_width": 16,
      "frame_height": 16,
      "frames": [
        0
      ]
    }
  ],
  "entity_commands": {
    "interact": {
      "enabled": true,
      "commands": [
        {
          "type": "run_entity_command",
          "entity_id": "dialogue_controller",
          "command_id": "open_dialogue",
          "dialogue_path": "dialogues/system/save_prompt.json",
          "dialogue_on_start": [
            {
              "type": "set_entity_var",
              "entity_id": "$self_id",
              "name": "pending_save_prompt_action",
              "value": ""
            }
          ],
          "dialogue_on_end": [
            {
              "type": "if",
              "op": "eq",
              "then": [
                {
                  "type": "save_game"
                }
              ],
              "left": {
                "$entity_var": {
                  "entity_id": "$self_id",
                  "name": "pending_save_prompt_action"
                }
              },
              "right": "save"
            },
            {
              "type": "set_entity_var",
              "entity_id": "$self_id",
              "name": "pending_save_prompt_action",
              "value": ""
            }
          ],
          "segment_hooks": [
            {},
            {
              "option_commands_by_id": {
                "save": [
                  {
                    "type": "set_entity_var",
                    "entity_id": "$self_id",
                    "name": "pending_save_prompt_action",
                    "value": "save"
                  }
                ]
              }
            }
          ],
          "allow_cancel": true,
          "entity_refs": {
            "instigator": "$ref_ids.instigator",
            "caller": "$self_id"
          }
        }
      ]
    }
  },
  "render_order": 10
}
