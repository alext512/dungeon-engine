{
  "kind": "lever_toggle",
  "solid": true,
  "variables": {
    "toggled": false
  },
  "visuals": [
    {
      "id": "main",
      "path": "assets/project/sprites/object_sheet.png",
      "frame_width": 16,
      "frame_height": 16,
      "frames": [1]
    }
  ],
  "events": {
    "interact": {
      "enabled": true,
      "commands": [
        {
          "type": "check_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "toggled",
          "op": "eq",
          "value": false,
          "then": [
            {
              "type": "run_event",
              "entity_id": "dialogue_controller",
              "event_id": "open_dialogue",
              "dialogue_id": "showcase/lever_open",
              "dialogue_on_start": [
                {
                  "type": "play_audio",
                  "path": "assets/project/sfx/push.wav"
                }
              ],
              "dialogue_on_end": [],
              "segment_hooks": [
                {
                  "on_end": [
                    {
                      "type": "run_detached_commands",
                      "commands": [
                        {
                          "type": "play_audio",
                          "path": "assets/project/sfx/bump.wav"
                        }
                      ]
                    }
                  ]
                },
                {
                  "on_end": [
                    {
                      "type": "set_var",
                      "scope": "entity",
                      "entity_id": "caller",
                      "name": "toggled",
                      "value": true,
                      "persistent": true
                    },
                    {
                      "type": "set_entity_field",
                      "entity_id": "$target_gate",
                      "field_name": "visible",
                      "value": false,
                      "persistent": true
                    },
                    {
                      "type": "set_entity_field",
                      "entity_id": "$target_gate",
                      "field_name": "solid",
                      "value": false,
                      "persistent": true
                    },
                    {
                      "type": "set_entity_field",
                      "entity_id": "caller",
                      "field_name": "visuals.main.tint",
                      "value": [150, 150, 150],
                      "persistent": true
                    }
                  ]
                }
              ],
              "allow_cancel": false,
              "actor_entity_id": "$actor_id",
              "caller_entity_id": "$self_id"
            }
          ],
          "else": [
            {
              "type": "run_event",
              "entity_id": "dialogue_controller",
              "event_id": "open_dialogue",
              "dialogue_id": "showcase/lever_close",
              "dialogue_on_start": [
                {
                  "type": "play_audio",
                  "path": "assets/project/sfx/push.wav"
                }
              ],
              "dialogue_on_end": [],
              "segment_hooks": [
                {
                  "on_end": [
                    {
                      "type": "run_detached_commands",
                      "commands": [
                        {
                          "type": "play_audio",
                          "path": "assets/project/sfx/bump.wav"
                        }
                      ]
                    }
                  ]
                },
                {
                  "on_end": [
                    {
                      "type": "set_var",
                      "scope": "entity",
                      "entity_id": "caller",
                      "name": "toggled",
                      "value": false,
                      "persistent": true
                    },
                    {
                      "type": "set_entity_field",
                      "entity_id": "$target_gate",
                      "field_name": "visible",
                      "value": true,
                      "persistent": true
                    },
                    {
                      "type": "set_entity_field",
                      "entity_id": "$target_gate",
                      "field_name": "solid",
                      "value": true,
                      "persistent": true
                    },
                    {
                      "type": "set_entity_field",
                      "entity_id": "caller",
                      "field_name": "visuals.main.tint",
                      "value": [255, 255, 255],
                      "persistent": true
                    }
                  ]
                }
              ],
              "allow_cancel": false,
              "actor_entity_id": "$actor_id",
              "caller_entity_id": "$self_id"
            }
          ]
        }
      ]
    }
  }
}
