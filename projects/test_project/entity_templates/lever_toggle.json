{
  "kind": "lever_toggle",
  "variables": {
    "toggled": false,
    "blocks_movement": true
  },
  "visuals": [
    {
      "id": "main",
      "path": "assets/project/sprites/object_sheet.png",
      "frame_width": 16,
      "frame_height": 16,
      "frames": [
        1
      ]
    }
  ],
  "entity_commands": {
    "interact": {
      "enabled": true,
      "commands": [
        {
          "type": "if",
          "op": "eq",
          "then": [
            {
              "type": "run_entity_command",
              "entity_id": "dialogue_controller",
              "command_id": "open_dialogue",
              "dialogue_path": "dialogues/showcase/lever_open.json",
              "dialogue_on_start": [
                {
                  "type": "play_audio",
                  "path": "assets/project/sfx/push.wav"
                }
              ],
              "dialogue_on_end": [],
              "segment_hooks": [
                {
                  "on_end": [
                    {
                      "type": "spawn_flow",
                      "commands": [
                        {
                          "type": "play_audio",
                          "path": "assets/project/sfx/bump.wav"
                        }
                      ]
                    }
                  ]
                },
                {
                  "on_end": [
                    {
                      "type": "set_entity_fields",
                      "entity_id": "$ref_ids.caller",
                      "set": {
                        "variables": {
                          "toggled": true
                        },
                        "visuals": {
                          "main": {
                            "tint": [
                              150,
                              150,
                              150
                            ]
                          }
                        }
                      },
                      "persistent": true
                    },
                    {
                      "type": "set_entity_fields",
                      "entity_id": "$target_gate",
                      "set": {
                        "fields": {
                          "visible": false
                        },
                        "variables": {
                          "blocks_movement": false
                        }
                      },
                      "persistent": true
                    }
                  ]
                }
              ],
              "allow_cancel": false,
              "entity_refs": {
                "instigator": "$ref_ids.instigator",
                "caller": "$self_id"
              }
            }
          ],
          "else": [
            {
              "type": "run_entity_command",
              "entity_id": "dialogue_controller",
              "command_id": "open_dialogue",
              "dialogue_path": "dialogues/showcase/lever_close.json",
              "dialogue_on_start": [
                {
                  "type": "play_audio",
                  "path": "assets/project/sfx/push.wav"
                }
              ],
              "dialogue_on_end": [],
              "segment_hooks": [
                {
                  "on_end": [
                    {
                      "type": "spawn_flow",
                      "commands": [
                        {
                          "type": "play_audio",
                          "path": "assets/project/sfx/bump.wav"
                        }
                      ]
                    }
                  ]
                },
                {
                  "on_end": [
                    {
                      "type": "set_entity_fields",
                      "entity_id": "$ref_ids.caller",
                      "set": {
                        "variables": {
                          "toggled": false
                        },
                        "visuals": {
                          "main": {
                            "tint": [
                              255,
                              255,
                              255
                            ]
                          }
                        }
                      },
                      "persistent": true
                    },
                    {
                      "type": "set_entity_fields",
                      "entity_id": "$target_gate",
                      "set": {
                        "fields": {
                          "visible": true
                        },
                        "variables": {
                          "blocks_movement": true
                        }
                      },
                      "persistent": true
                    }
                  ]
                }
              ],
              "allow_cancel": false,
              "entity_refs": {
                "instigator": "$ref_ids.instigator",
                "caller": "$self_id"
              }
            }
          ],
          "left": {
            "$entity_var": {
              "entity_id": "$self_id",
              "name": "toggled"
            }
          },
          "right": false
        }
      ]
    }
  },
  "render_order": 10
}
