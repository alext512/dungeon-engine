  "enter_commands": [
    {
      "type": "run_entity_command",
      "entity_id": "dialogue_controller",
      "command_id": "open_dialogue",
      "dialogue_path": "dialogues/system/title_menu.json",
      "dialogue_on_start": [
        {
          "type": "set_entity_var",
          "entity_id": "$self_id",
          "name": "pending_title_menu_action",
          "value": ""
        }
      ],
      "dialogue_on_end": [
        {
          "type": "if",
          "op": "eq",
          "then": [
            {
              "type": "new_game",
              "area_id": "areas/village_square",
              "entry_id": "startup",
              "camera_follow": {
                "mode": "entity",
                "entity_id": "player"
              }
            }
          ],
          "left": {
            "$entity_var": {
              "entity_id": "$self_id",
              "name": "pending_title_menu_action"
            }
          },
          "right": "new_game"
        },
        {
          "type": "if",
          "op": "eq",
          "then": [
            {
              "type": "load_game"
            }
          ],
          "left": {
            "$entity_var": {
              "entity_id": "$self_id",
              "name": "pending_title_menu_action"
            }
          },
          "right": "load_game"
        },
        {
          "type": "if",
          "op": "eq",
          "then": [
            {
              "type": "quit_game"
            }
          ],
          "left": {
            "$entity_var": {
              "entity_id": "$self_id",
              "name": "pending_title_menu_action"
            }
          },
          "right": "exit"
        },
        {
          "type": "set_entity_var",
          "entity_id": "$self_id",
          "name": "pending_title_menu_action",
          "value": ""
        }
      ],
      "segment_hooks": [
        {
          "option_commands_by_id": {
            "new_game": [
              {
                "type": "set_entity_var",
                "entity_id": "$self_id",
                "name": "pending_title_menu_action",
                "value": "new_game"
              }
            ],
            "load_game": [
              {
                "type": "set_entity_var",
                "entity_id": "$self_id",
                "name": "pending_title_menu_action",
                "value": "load_game"
              }
            ],
            "exit": [
              {
                "type": "set_entity_var",
                "entity_id": "$self_id",
                "name": "pending_title_menu_action",
                "value": "exit"
              }
            ]
          }
        }
      ],
      "allow_cancel": false,
      "entity_refs": {
        "instigator": "dialogue_controller",
        "caller": "dialogue_controller"
      }
    }
  ],
  "entities": [
