{
  "params": [],
  "commands": [
    {
      "type": "if",
      "op": "eq",
      "then": [
        {
          "type": "if",
          "op": "eq",
          "then": [
            {
              "type": "run_project_command",
              "command_id": "commands/dialogue/confirm_choice"
            }
          ],
          "else": [
            {
              "type": "if",
              "op": "eq",
              "then": [],
              "else": [
                {
                  "type": "run_project_command",
                  "command_id": "commands/dialogue/advance_text"
                }
              ],
              "left": {
                "$entity_var": {
                  "entity_id": "$self_id",
                  "name": "dialogue_current_advance_mode"
                }
              },
              "right": "timer"
            }
          ],
          "left": {
            "$entity_var": {
              "entity_id": "$self_id",
              "name": "dialogue_phase"
            }
          },
          "right": "choice"
        }
      ],
      "left": {
        "$entity_var": {
          "entity_id": "$self_id",
          "name": "dialogue_open"
        }
      },
      "right": true
    }
  ]
}
