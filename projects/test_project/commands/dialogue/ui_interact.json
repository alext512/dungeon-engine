{
  "id": "dialogue/ui_interact",
  "commands": [
    {
      "type": "check_var",
      "scope": "entity",
      "entity_id": "self",
      "name": "mode",
      "op": "eq",
      "value": "pages",
      "then": [
        {
          "type": "run_named_command",
          "command_id": "dialogue/ui_interact_pages"
        }
      ],
      "else": [
        {
          "type": "check_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "mode",
          "op": "eq",
          "value": "menu",
          "then": [
            {
              "type": "run_named_command",
              "command_id": "$self.confirm_command_id"
            }
          ]
        }
      ]
    }
  ]
}
