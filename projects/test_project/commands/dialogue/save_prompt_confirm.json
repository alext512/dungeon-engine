    {
      "type": "check_var",
      "scope": "entity",
      "entity_id": "self",
      "name": "choice_selected_index",
      "op": "eq",
      "value": 0,
      "then": [
        {
          "type": "run_named_command",
          "command_id": "dialogue/ui_close"
