{
  "id": "dialogue/pause_menu_open",
  "commands": [
    {
      "type": "run_named_command",
      "command_id": "dialogue/ui_clear_choices"
    },
    {
      "type": "remove_screen_element",
      "element_id": "dialogue_text"
    },
    {
      "type": "remove_screen_element",
      "element_id": "dialogue_portrait"
    },
    {
      "type": "set_var",
      "scope": "entity",
      "entity_id": "self",
      "name": "mode",
      "value": "menu"
    },
    {
      "type": "set_var",
      "scope": "entity",
      "entity_id": "self",
      "name": "after_pages_command_id",
      "value": "dialogue/ui_close"
    },
    {
      "type": "set_var",
      "scope": "entity",
      "entity_id": "self",
      "name": "move_up_command_id",
      "value": "dialogue/ui_menu_move_up"
    },
    {
      "type": "set_var",
      "scope": "entity",
      "entity_id": "self",
      "name": "move_down_command_id",
      "value": "dialogue/ui_menu_move_down"
    },
    {
      "type": "set_var",
      "scope": "entity",
      "entity_id": "self",
      "name": "refresh_command_id",
      "value": "dialogue/pause_menu_refresh_choices"
    },
    {
      "type": "set_var",
      "scope": "entity",
      "entity_id": "self",
      "name": "confirm_command_id",
      "value": "dialogue/pause_menu_confirm"
    },
    {
      "type": "set_var",
      "scope": "entity",
      "entity_id": "self",
      "name": "choice_selected_index",
      "value": 0
    },
    {
      "type": "set_var",
      "scope": "entity",
      "entity_id": "self",
      "name": "choice_scroll_offset",
      "value": 0
    },
    {
      "type": "set_var",
      "scope": "entity",
      "entity_id": "self",
      "name": "choice_max_index",
      "value": 2
    },
    {
      "type": "set_var",
      "scope": "entity",
      "entity_id": "self",
      "name": "choice_bottom_visible_index",
      "value": 2
    },
    {
      "type": "set_var",
      "scope": "entity",
      "entity_id": "self",
      "name": "selected_visible_slot",
      "value": 0
    },
    {
      "type": "show_screen_image",
      "element_id": "dialogue_panel",
      "path": "$project.dialogue.panel_path",
      "x": 0,
      "y": "$project.display.internal_height",
      "anchor": "bottomleft",
      "layer": 100
    },
    {
      "type": "run_named_command",
      "command_id": "dialogue/pause_menu_refresh_choices"
    },
    {
      "type": "push_active_entity",
      "entity_id": "self"
    }
  ]
}
