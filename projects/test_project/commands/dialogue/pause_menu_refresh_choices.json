        {
          "type": "run_named_command",
          "command_id": "dialogue/ui_render_choice_slot_0",
          "text": "Continue exploring.",
          "marker_text": "",
          "text_color": [238, 242, 248]
        },
        {
          "type": "run_named_command",
          "command_id": "dialogue/ui_render_choice_slot_1",
          "text": "Load a save file.",
          "marker_text": "",
          "text_color": [238, 242, 248]
        },
        {
          "type": "run_named_command",
          "command_id": "dialogue/ui_render_choice_slot_2",
          "text": "Exit the game.",
          "marker_text": "-",
          "text_color": [245, 232, 190]
        }
      ]
    },
    {
      "type": "run_named_command",
      "command_id": "dialogue/ui_maybe_start_selected_marquee"
    }
