{
  "id": "dialogue/pause_menu_refresh_choices",
  "commands": [
    {
      "type": "show_screen_text",
      "element_id": "dialogue_more_top",
      "text": "",
      "x": "$project.dialogue.choice_more_top.x",
      "y": "$project.dialogue.choice_more_top.y",
      "layer": 101,
      "color": [238, 242, 248]
    },
    {
      "type": "show_screen_text",
      "element_id": "dialogue_more_bottom",
      "text": "",
      "x": "$project.dialogue.choice_more_bottom.x",
      "y": "$project.dialogue.choice_more_bottom.y",
      "layer": 101,
      "color": [238, 242, 248]
    },
    {
      "type": "check_var",
      "scope": "entity",
      "entity_id": "self",
      "name": "choice_selected_index",
      "op": "eq",
      "value": 0,
      "then": [
        {
          "type": "set_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "selected_visible_slot",
          "value": 0
        },
        {
          "type": "run_named_command",
          "command_id": "dialogue/ui_render_choice_slot_0",
          "text": "Continue exploring.",
          "marker_text": "-",
          "text_color": [245, 232, 190]
        },
        {
          "type": "run_named_command",
          "command_id": "dialogue/ui_render_choice_slot_1",
          "text": "Load a save file.",
          "marker_text": "",
          "text_color": [238, 242, 248]
        },
        {
          "type": "run_named_command",
          "command_id": "dialogue/ui_render_choice_slot_2",
          "text": "Exit the game.",
          "marker_text": "",
          "text_color": [238, 242, 248]
        }
      ]
    },
    {
      "type": "check_var",
      "scope": "entity",
      "entity_id": "self",
      "name": "choice_selected_index",
      "op": "eq",
      "value": 1,
      "then": [
        {
          "type": "set_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "selected_visible_slot",
          "value": 1
        },
        {
          "type": "run_named_command",
          "command_id": "dialogue/ui_render_choice_slot_0",
          "text": "Continue exploring.",
          "marker_text": "",
          "text_color": [238, 242, 248]
        },
        {
          "type": "run_named_command",
          "command_id": "dialogue/ui_render_choice_slot_1",
          "text": "Load a save file.",
          "marker_text": "-",
          "text_color": [245, 232, 190]
        },
        {
          "type": "run_named_command",
          "command_id": "dialogue/ui_render_choice_slot_2",
          "text": "Exit the game.",
          "marker_text": "",
          "text_color": [238, 242, 248]
        }
      ]
    },
    {
      "type": "check_var",
      "scope": "entity",
      "entity_id": "self",
      "name": "choice_selected_index",
      "op": "eq",
      "value": 2,
      "then": [
        {
          "type": "set_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "selected_visible_slot",
          "value": 2
