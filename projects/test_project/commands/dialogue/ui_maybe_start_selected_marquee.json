{
  "id": "dialogue/ui_maybe_start_selected_marquee",
  "commands": [
    {
      "type": "increment_var",
      "scope": "entity",
      "entity_id": "self",
      "name": "marquee_token",
      "amount": 1
    },
    {
      "type": "check_var",
      "scope": "entity",
      "entity_id": "self",
      "name": "selected_visible_slot",
      "op": "eq",
      "value": 0,
      "then": [
        {
          "type": "check_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "slot_0_has_more",
          "op": "eq",
          "value": true,
          "then": [
            {
              "type": "run_detached_commands",
              "commands": [
                {
                  "type": "run_event",
                  "entity_id": "self",
                  "event_id": "marquee_slot_0",
                  "token": "$self.marquee_token"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "check_var",
      "scope": "entity",
      "entity_id": "self",
      "name": "selected_visible_slot",
      "op": "eq",
      "value": 1,
      "then": [
        {
          "type": "check_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "slot_1_has_more",
          "op": "eq",
          "value": true,
          "then": [
            {
              "type": "run_detached_commands",
              "commands": [
                {
                  "type": "run_event",
                  "entity_id": "self",
                  "event_id": "marquee_slot_1",
                  "token": "$self.marquee_token"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "check_var",
      "scope": "entity",
      "entity_id": "self",
      "name": "selected_visible_slot",
      "op": "eq",
      "value": 2,
      "then": [
        {
          "type": "check_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "slot_2_has_more",
          "op": "eq",
          "value": true,
          "then": [
            {
              "type": "run_detached_commands",
              "commands": [
                {
                  "type": "run_event",
                  "entity_id": "self",
                  "event_id": "marquee_slot_2",
                  "token": "$self.marquee_token"
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
