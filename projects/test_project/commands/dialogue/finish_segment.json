{
  "params": [],
  "commands": [
    {
      "type": "set_entity_var",
      "entity_id": "$self_id",
      "name": "dialogue_finish_revision_snapshot",
      "value": "$self.dialogue_revision"
    },
    {
      "type": "run_commands",
      "commands": "$self.dialogue_current_segment_on_end_commands",
      "entity_refs": {
        "instigator": "$self.dialogue_actor_id",
        "caller": "$self.dialogue_caller_id"
      }
    },
    {
      "type": "if",
      "op": "eq",
      "then": [
        {
          "type": "if",
          "op": "eq",
          "then": [
            {
              "type": "set_entity_var",
              "entity_id": "$self_id",
              "name": "dialogue_next_segment_index",
              "value": "$self.dialogue_segment_index"
            },
            {
              "type": "add_entity_var",
              "entity_id": "$self_id",
              "name": "dialogue_next_segment_index",
              "amount": 1
            },
            {
              "type": "set_entity_var",
              "entity_id": "$self_id",
              "name": "dialogue_segment_index",
              "value": "$self.dialogue_next_segment_index"
            },
            {
              "type": "set_entity_var",
              "entity_id": "$self_id",
              "name": "dialogue_source_page_index",
              "value": 0
            },
            {
              "type": "set_entity_var",
              "entity_id": "$self_id",
              "name": "dialogue_text_line_offset",
              "value": 0
            },
            {
              "type": "set_entity_var",
              "entity_id": "$self_id",
              "name": "dialogue_choice_index",
              "value": 0
            },
            {
              "type": "set_entity_var",
              "entity_id": "$self_id",
              "name": "dialogue_choice_scroll_offset",
              "value": 0
            },
            {
              "type": "run_project_command",
              "command_id": "commands/dialogue/show_current_segment"
            }
          ],
          "left": {
            "$entity_var": {
              "entity_id": "$self_id",
              "name": "dialogue_revision"
            }
          },
          "right": "$self.dialogue_finish_revision_snapshot"
        }
      ],
      "left": {
        "$entity_var": {
          "entity_id": "$self_id",
          "name": "dialogue_open"
        }
      },
      "right": true
    }
  ]
}
