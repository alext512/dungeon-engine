{
  "id": "title/move_up",
  "commands": [
    {
      "type": "check_var",
      "scope": "entity",
      "entity_id": "self",
      "name": "menu_index",
      "op": "eq",
      "value": 0,
      "then": [
        {
          "type": "set_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "menu_index",
          "value": 2
        }
      ],
      "else": [
        {
          "type": "check_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "menu_index",
          "op": "eq",
          "value": 1,
          "then": [
            {
              "type": "set_var",
              "scope": "entity",
              "entity_id": "self",
              "name": "menu_index",
              "value": 0
            }
          ],
          "else": [
            {
              "type": "set_var",
              "scope": "entity",
              "entity_id": "self",
              "name": "menu_index",
              "value": 1
            }
          ]
        }
      ]
    },
    {
      "type": "run_named_command",
      "command_id": "title/refresh_menu"
    }
  ]
}
