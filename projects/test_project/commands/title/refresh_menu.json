{
  "id": "title/refresh_menu",
  "commands": [
    {
      "type": "check_var",
      "scope": "entity",
      "entity_id": "self",
      "name": "menu_index",
      "op": "eq",
      "value": 0,
      "then": [
        {
          "type": "set_sprite_frame",
          "entity_id": "menu_new_game",
          "frame": 1
        },
        {
          "type": "set_sprite_frame",
          "entity_id": "menu_load_game",
          "frame": 0
        },
        {
          "type": "set_sprite_frame",
          "entity_id": "menu_exit_game",
          "frame": 0
        }
      ],
      "else": [
        {
          "type": "check_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "menu_index",
          "op": "eq",
          "value": 1,
          "then": [
            {
              "type": "set_sprite_frame",
              "entity_id": "menu_new_game",
              "frame": 0
            },
            {
              "type": "set_sprite_frame",
              "entity_id": "menu_load_game",
              "frame": 1
            },
            {
              "type": "set_sprite_frame",
              "entity_id": "menu_exit_game",
              "frame": 0
            }
          ],
          "else": [
            {
              "type": "set_sprite_frame",
              "entity_id": "menu_new_game",
              "frame": 0
            },
            {
              "type": "set_sprite_frame",
              "entity_id": "menu_load_game",
              "frame": 0
            },
            {
              "type": "set_sprite_frame",
              "entity_id": "menu_exit_game",
              "frame": 1
            }
          ]
        }
      ]
    }
  ]
}
