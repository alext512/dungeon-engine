{
  "id": "title/confirm",
  "commands": [
    {
      "type": "check_var",
      "scope": "entity",
      "entity_id": "self",
      "name": "menu_index",
      "op": "eq",
      "value": 0,
      "then": [
        {
          "type": "run_named_command",
          "command_id": "title/start_new_game"
        }
      ],
      "else": [
        {
          "type": "check_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "menu_index",
          "op": "eq",
          "value": 1,
          "then": [
            {
              "type": "run_named_command",
              "command_id": "title/load_game"
            }
          ],
          "else": [
            {
              "type": "run_named_command",
              "command_id": "title/exit_game"
            }
          ]
        }
      ]
    }
  ]
}
