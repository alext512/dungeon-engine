{
  "kind": "block",
  "solid": true,
  "pushable": true,
  "sprite": {
      "path": "assets/project/sprites/object_sheet.png",
    "frame_width": 16,
    "frame_height": 16,
    "frames": [0]
  },
  "events": {
    "push_from_left": {
      "enabled": true,
      "commands": [
        {
          "type": "run_event",
          "entity_id": "self",
          "event_id": "push",
          "direction": "right"
        }
      ]
    },
    "push_from_right": {
      "enabled": true,
      "commands": [
        {
          "type": "run_event",
          "entity_id": "self",
          "event_id": "push",
          "direction": "left"
        }
      ]
    },
    "push_from_up": {
      "enabled": true,
      "commands": [
        {
          "type": "run_event",
          "entity_id": "self",
          "event_id": "push",
          "direction": "down"
        }
      ]
    },
    "push_from_down": {
      "enabled": true,
      "commands": [
        {
          "type": "run_event",
          "entity_id": "self",
          "event_id": "push",
          "direction": "up"
        }
      ]
    },
    "push": {
      "enabled": true,
      "commands": [
        {
          "type": "run_named_command",
          "command_id": "push_one_tile",
          "direction": "$direction",
          "frames_needed": "$project.movement.ticks_per_tile"
        }
      ]
    }
  }
}
