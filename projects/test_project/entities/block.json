{
  "kind": "block",
  "solid": true,
  "pushable": true,
  "sprite": {
      "path": "assets/project/sprites/object_sheet.png",
    "frame_width": 16,
    "frame_height": 16,
    "frames": [0]
  },
  "events": {
    "push_from_left": {
      "enabled": true,
      "commands": [
        {
          "type": "query_facing_state",
          "entity_id": "self",
          "direction": "right",
          "store_state_var": "push_attempt_state"
        },
        {
          "type": "check_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "push_attempt_state",
          "op": "eq",
          "value": "free",
          "then": [
            {
              "type": "play_audio",
              "path": "assets/project/sfx/push.wav"
            },
            {
              "type": "move_entity_one_tile",
              "entity_id": "self",
              "direction": "right",
              "frames_needed": 16,
              "allow_push": false,
              "wait": false
            }
          ]
        }
      ]
    },
    "push_from_right": {
      "enabled": true,
      "commands": [
