{
  "kind": "player",
  "solid": false,
  "visible": false,
  "input_map": {
    "move_up": "title_move_up",
    "move_down": "title_move_down",
    "move_left": "",
    "move_right": "",
    "interact": "title_confirm"
  },
  "variables": {
    "walk_phase": 0,
    "menu_index": 0,
    "title_started": false
  },
  "sprite": {
    "path": "assets/16x16-RPG-characters/sprites/new-style/chibi-layered.png",
    "frame_width": 16,
    "frame_height": 16,
    "frames": [0],
    "animation_fps": 0,
    "animate_when_moving": false
  },
  "events": {
    "play_bump_sound": {
      "enabled": true,
      "commands": [
        {
          "type": "play_audio",
          "path": "assets/project/sfx/bump.wav"
        },
        {
          "type": "set_event_enabled",
          "entity_id": "self",
          "event_id": "play_bump_sound",
          "enabled": false
        },
        {
          "type": "wait_frames",
          "frames": 16
        },
        {
          "type": "set_event_enabled",
          "entity_id": "self",
          "event_id": "play_bump_sound",
          "enabled": true
        }
      ]
    },
    "title_move_up": {
      "enabled": true,
      "commands": [
        {
          "type": "check_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "menu_index",
          "op": "eq",
          "value": 0,
          "then": [
            {
              "type": "set_var",
              "scope": "entity",
              "entity_id": "self",
              "name": "menu_index",
              "value": 2
            }
          ],
          "else": [
            {
              "type": "check_var",
              "scope": "entity",
              "entity_id": "self",
              "name": "menu_index",
              "op": "eq",
              "value": 1,
              "then": [
                {
                  "type": "set_var",
                  "scope": "entity",
                  "entity_id": "self",
                  "name": "menu_index",
                  "value": 0
                }
              ],
              "else": [
                {
                  "type": "set_var",
                  "scope": "entity",
                  "entity_id": "self",
                  "name": "menu_index",
                  "value": 1
                }
              ]
            }
          ]
        },
        {
          "type": "run_event",
          "entity_id": "self",
          "event_id": "refresh_menu"
        },
        {
          "type": "wait_for_direction_release",
          "direction": "up"
        }
      ]
    },
    "title_move_down": {
      "enabled": true,
      "commands": [
        {
          "type": "check_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "menu_index",
          "op": "eq",
          "value": 2,
          "then": [
            {
              "type": "set_var",
              "scope": "entity",
              "entity_id": "self",
              "name": "menu_index",
              "value": 0
            }
          ],
          "else": [
            {
              "type": "check_var",
              "scope": "entity",
              "entity_id": "self",
              "name": "menu_index",
              "op": "eq",
              "value": 0,
              "then": [
                {
                  "type": "set_var",
                  "scope": "entity",
                  "entity_id": "self",
                  "name": "menu_index",
                  "value": 1
                }
              ],
              "else": [
                {
                  "type": "set_var",
                  "scope": "entity",
                  "entity_id": "self",
                  "name": "menu_index",
                  "value": 2
                }
              ]
            }
          ]
        },
        {
          "type": "run_event",
          "entity_id": "self",
          "event_id": "refresh_menu"
        },
        {
          "type": "wait_for_direction_release",
          "direction": "down"
        }
      ]
    },
    "title_confirm": {
      "enabled": true,
      "commands": [
        {
          "type": "check_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "menu_index",
          "op": "eq",
          "value": 0,
          "then": [
            {
              "type": "run_event",
              "entity_id": "self",
              "event_id": "start_new_game"
            }
          ],
          "else": [
            {
              "type": "check_var",
              "scope": "entity",
              "entity_id": "self",
              "name": "menu_index",
              "op": "eq",
              "value": 1,
              "then": [
                {
                  "type": "run_event",
                  "entity_id": "self",
                  "event_id": "load_game"
                }
              ],
              "else": [
                {
                  "type": "run_event",
                  "entity_id": "self",
                  "event_id": "exit_game"
                }
              ]
            }
          ]
        }
      ]
    },
    "refresh_menu": {
      "enabled": true,
      "commands": [
        {
          "type": "check_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "menu_index",
          "op": "eq",
          "value": 0,
          "then": [
            {
              "type": "set_sprite_frame",
              "entity_id": "menu_new_game",
              "frame": 1
            },
            {
              "type": "set_sprite_frame",
              "entity_id": "menu_load_game",
              "frame": 0
            },
            {
              "type": "set_sprite_frame",
              "entity_id": "menu_exit_game",
              "frame": 0
            }
          ],
          "else": [
            {
              "type": "check_var",
              "scope": "entity",
              "entity_id": "self",
              "name": "menu_index",
              "op": "eq",
              "value": 1,
              "then": [
                {
                  "type": "set_sprite_frame",
                  "entity_id": "menu_new_game",
                  "frame": 0
                },
                {
                  "type": "set_sprite_frame",
                  "entity_id": "menu_load_game",
                  "frame": 1
                },
                {
                  "type": "set_sprite_frame",
                  "entity_id": "menu_exit_game",
                  "frame": 0
                }
              ],
              "else": [
                {
                  "type": "set_sprite_frame",
                  "entity_id": "menu_new_game",
                  "frame": 0
                },
                {
                  "type": "set_sprite_frame",
                  "entity_id": "menu_load_game",
                  "frame": 0
                },
                {
                  "type": "set_sprite_frame",
                  "entity_id": "menu_exit_game",
                  "frame": 1
                }
              ]
            }
          ]
        }
      ]
    },
    "start_new_game": {
      "enabled": true,
      "commands": [
        {
          "type": "change_area",
          "area_id": "village_square"
        }
      ]
    },
    "load_game": {
      "enabled": true,
      "commands": [
        {
          "type": "load_game"
        }
      ]
    },
    "exit_game": {
      "enabled": true,
      "commands": [
        {
          "type": "quit_game"
        }
      ]
    },
    "interact": {
      "enabled": true,
      "commands": [
        {
          "type": "interact_facing",
          "entity_id": "self"
        }
      ]
    },
    "move_up": {
      "enabled": true,
      "commands": [
        {
          "type": "run_event",
          "entity_id": "self",
          "event_id": "move",
          "direction": "up",
          "flip_x": false,
          "push_event_id": "push_from_down",
          "phase_a_frames": [5, 2],
          "phase_b_frames": [8, 2],
          "idle_frame": 2
        }
      ]
    },
    "move_down": {
      "enabled": true,
      "commands": [
        {
          "type": "run_event",
          "entity_id": "self",
          "event_id": "move",
          "direction": "down",
          "flip_x": false,
          "push_event_id": "push_from_up",
          "phase_a_frames": [3, 0],
          "phase_b_frames": [6, 0],
          "idle_frame": 0
        }
      ]
    },
    "move_left": {
      "enabled": true,
      "commands": [
        {
          "type": "run_event",
          "entity_id": "self",
          "event_id": "move",
          "direction": "left",
          "flip_x": false,
          "push_event_id": "push_from_right",
          "phase_a_frames": [4, 1],
          "phase_b_frames": [7, 1],
          "idle_frame": 1
        }
      ]
    },
    "move_right": {
      "enabled": true,
      "commands": [
        {
          "type": "run_event",
          "entity_id": "self",
          "event_id": "move",
          "direction": "right",
          "flip_x": true,
          "push_event_id": "push_from_left",
          "phase_a_frames": [4, 1],
          "phase_b_frames": [7, 1],
          "idle_frame": 1
        }
      ]
    },
    "move": {
      "enabled": true,
      "commands": [
        {
          "type": "set_sprite_flip_x",
          "entity_id": "self",
          "flip_x": "$flip_x"
        },
        {
          "type": "run_named_command",
          "command_id": "attempt_move_one_tile",
          "direction": "$direction",
          "push_event_id": "$push_event_id",
          "phase_a_frames": "$phase_a_frames",
          "phase_b_frames": "$phase_b_frames",
          "idle_frame": "$idle_frame",
          "frames_per_sprite_change": "$half:project.movement.ticks_per_tile",
          "frames_needed": "$project.movement.ticks_per_tile"
        }
      ]
    }
  }
}

