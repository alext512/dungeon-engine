                      "name": "slot_1_has_more",
                      "op": "eq",
                      "value": true,
                      "then": [
                        {
                          "type": "run_event",
                          "entity_id": "self",
                          "event_id": "marquee_slot_1",
                          "token": "$token"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    "marquee_slot_2": {
