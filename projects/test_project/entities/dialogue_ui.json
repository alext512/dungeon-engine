{
  "kind": "system",
  "solid": false,
  "visible": false,
  "input_map": {
    "move_up": "move_up",
    "move_down": "move_down",
    "interact": "interact",
    "menu": "menu"
  },
  "variables": {
    "mode": "",
    "after_pages_event_id": "close",
    "command_source_entity_id": null,
    "portrait_path": "",
    "portrait_frame_width": null,
    "portrait_frame_height": null,
    "portrait_frame": 0,
    "text_box_x": 8,
    "text_box_y": 154,
    "text_box_width": 240,
    "choice_marker_x": 8,
    "choice_text_x": 16,
    "choice_width": 232,
    "page_text": "",
    "page_has_more": false,
    "on_finish_commands": [],
    "finish_commands_snapshot": [],
    "selected_choice_commands": [],
    "prompt_dialogue_id": "",
    "prompt_text": "",
    "prompt_pages": [],
    "prompt_page_count": 0,
    "menu_choices": [],
    "choice_count": 0,
    "choice_selected_index": 0,
    "choice_scroll_offset": 0,
    "choice_bottom_visible_index": 0,
    "selected_visible_slot": 0,
    "temp_last_index": 0,
    "temp_index_0": 0,
    "temp_index_1": 1,
    "temp_index_2": 2,
    "visible_choice_0": {
      "text": "",
      "commands": []
    },
    "visible_choice_1": {
      "text": "",
      "commands": []
    },
    "visible_choice_2": {
      "text": "",
      "commands": []
    },
    "selected_choice": {
      "text": "",
      "commands": []
    },
    "marquee_token": 0,
    "slot_0_text": "",
    "slot_1_text": "",
    "slot_2_text": "",
    "slot_0_has_more": false,
    "slot_1_has_more": false,
    "slot_2_has_more": false
  },
  "events": {
    "show_message": {
      "enabled": true,
      "commands": [
        {
          "type": "set_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "command_source_entity_id",
          "value": "$command_source_entity_id"
        },
        {
          "type": "set_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "on_finish_commands",
          "value": "$on_finish_commands"
        },
        {
          "type": "run_event",
          "entity_id": "self",
          "event_id": "_configure_layout",
          "portrait_path": "$portrait_path"
        },
        {
          "type": "run_event",
          "entity_id": "self",
          "event_id": "_present_frame",
          "portrait_path": "$portrait_path",
          "portrait_frame_width": "$portrait_frame_width",
          "portrait_frame_height": "$portrait_frame_height",
          "portrait_frame": "$portrait_frame"
        },
        {
          "type": "push_active_entity",
          "entity_id": "self"
        },
        {
          "type": "run_commands",
          "commands": "$on_start_commands",
          "source_entity_id": "$self.command_source_entity_id"
        },
        {
          "type": "run_event",
          "entity_id": "self",
          "event_id": "_open_pages_source",
          "dialogue_id": "$dialogue_id",
          "text": "$text",
          "pages": "$pages",
          "after_pages_event_id": "_finish_dialogue"
        }
      ]
    },
    "show_choice_dialogue": {
      "enabled": true,
      "commands": [
        {
          "type": "set_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "command_source_entity_id",
          "value": "$command_source_entity_id"
        },
        {
          "type": "set_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "on_finish_commands",
          "value": "$on_finish_commands"
        },
        {
          "type": "set_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "prompt_dialogue_id",
          "value": "$prompt_dialogue_id"
        },
        {
          "type": "set_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "prompt_text",
          "value": "$prompt_text"
        },
        {
          "type": "set_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "prompt_pages",
          "value": "$prompt_pages"
        },
        {
          "type": "set_var_length",
          "scope": "entity",
          "entity_id": "self",
          "name": "prompt_page_count",
          "value": "$prompt_pages"
        },
        {
          "type": "set_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "menu_choices",
          "value": "$choices"
        },
        {
          "type": "set_var_length",
          "scope": "entity",
          "entity_id": "self",
          "name": "choice_count",
          "value": "$choices"
        },
        {
          "type": "run_event",
          "entity_id": "self",
          "event_id": "_configure_layout",
          "portrait_path": "$portrait_path"
        },
        {
          "type": "run_event",
          "entity_id": "self",
          "event_id": "_present_frame",
          "portrait_path": "$portrait_path",
          "portrait_frame_width": "$portrait_frame_width",
          "portrait_frame_height": "$portrait_frame_height",
          "portrait_frame": "$portrait_frame"
        },
        {
          "type": "push_active_entity",
          "entity_id": "self"
        },
        {
          "type": "run_commands",
          "commands": "$on_start_commands",
          "source_entity_id": "$self.command_source_entity_id"
        },
        {
          "type": "check_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "prompt_dialogue_id",
          "op": "neq",
          "value": "",
          "then": [
            {
              "type": "run_event",
              "entity_id": "self",
              "event_id": "_open_pages_source",
              "dialogue_id": "$self.prompt_dialogue_id",
              "text": null,
              "pages": null,
              "after_pages_event_id": "open_choice_menu"
            }
          ],
          "else": [
            {
              "type": "check_var",
              "scope": "entity",
              "entity_id": "self",
              "name": "prompt_text",
              "op": "neq",
              "value": "",
              "then": [
                {
                  "type": "run_event",
                  "entity_id": "self",
                  "event_id": "_open_pages_source",
                  "dialogue_id": null,
                  "text": "$self.prompt_text",
                  "pages": null,
                  "after_pages_event_id": "open_choice_menu"
                }
              ],
              "else": [
                {
                  "type": "check_var",
                  "scope": "entity",
                  "entity_id": "self",
                  "name": "prompt_page_count",
                  "op": "gt",
                  "value": 0,
                  "then": [
                    {
                      "type": "run_event",
                      "entity_id": "self",
                      "event_id": "_open_pages_source",
                      "dialogue_id": null,
                      "text": null,
                      "pages": "$self.prompt_pages",
                      "after_pages_event_id": "open_choice_menu"
                    }
                  ],
                  "else": [
                    {
                      "type": "run_event",
                      "entity_id": "self",
                      "event_id": "open_choice_menu"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    "open_choice_menu": {
      "enabled": true,
      "commands": [
        {
          "type": "remove_screen_element",
          "element_id": "dialogue_text"
        },
        {
          "type": "set_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "mode",
          "value": "menu"
        },
        {
          "type": "set_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "choice_selected_index",
          "value": 0
        },
        {
          "type": "set_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "choice_scroll_offset",
          "value": 0
        },
        {
          "type": "set_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "temp_last_index",
          "value": 0
        },
        {
          "type": "check_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "choice_count",
          "op": "gt",
          "value": 0,
          "then": [
            {
              "type": "set_var",
              "scope": "entity",
              "entity_id": "self",
              "name": "temp_last_index",
              "value": "$self.choice_count"
            },
            {
              "type": "increment_var",
              "scope": "entity",
              "entity_id": "self",
              "name": "temp_last_index",
              "amount": -1
            }
          ]
        },
        {
          "type": "run_event",
          "entity_id": "self",
          "event_id": "_refresh_menu"
        }
      ]
    },
    "close": {
      "enabled": true,
      "commands": [
        {
          "type": "run_event",
          "entity_id": "self",
          "event_id": "_close_without_finish"
        }
      ]
    },
    "menu": {
      "enabled": true,
      "commands": [
        {
          "type": "check_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "mode",
          "op": "neq",
          "value": "",
          "then": [
            {
              "type": "run_event",
              "entity_id": "self",
              "event_id": "_close_without_finish"
            }
          ]
        }
      ]
    },
    "interact": {
      "enabled": true,
      "commands": [
        {
          "type": "check_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "mode",
          "op": "eq",
          "value": "pages",
          "then": [
            {
              "type": "run_event",
              "entity_id": "self",
              "event_id": "_interact_pages"
            }
          ],
          "else": [
            {
              "type": "check_var",
              "scope": "entity",
              "entity_id": "self",
              "name": "mode",
              "op": "eq",
              "value": "menu",
              "then": [
                {
                  "type": "run_event",
                  "entity_id": "self",
                  "event_id": "_confirm_choice"
                }
              ]
            }
          ]
        }
      ]
    },
    "move_up": {
      "enabled": true,
      "commands": [
        {
          "type": "check_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "mode",
          "op": "eq",
          "value": "menu",
          "then": [
            {
              "type": "run_event",
              "entity_id": "self",
              "event_id": "_move_choice_up"
            }
          ]
        }
      ]
    },
    "move_down": {
      "enabled": true,
      "commands": [
        {
          "type": "check_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "mode",
          "op": "eq",
          "value": "menu",
          "then": [
            {
              "type": "run_event",
              "entity_id": "self",
              "event_id": "_move_choice_down"
            }
          ]
        }
      ]
    },
    "_configure_layout": {
      "enabled": true,
      "commands": [
        {
          "type": "set_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "portrait_path",
          "value": "$portrait_path"
        },
        {
          "type": "check_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "portrait_path",
          "op": "neq",
          "value": "",
          "then": [
            {
              "type": "set_var",
              "scope": "entity",
              "entity_id": "self",
              "name": "text_box_x",
              "value": "$project.dialogue.portrait_box.x"
            },
            {
              "type": "set_var",
              "scope": "entity",
              "entity_id": "self",
              "name": "text_box_y",
              "value": "$project.dialogue.portrait_box.y"
            },
            {
              "type": "set_var",
              "scope": "entity",
              "entity_id": "self",
              "name": "text_box_width",
              "value": "$project.dialogue.portrait_box.width"
            },
            {
              "type": "set_var",
              "scope": "entity",
              "entity_id": "self",
              "name": "choice_marker_x",
              "value": "$project.dialogue.choice_box.marker_x"
            },
            {
              "type": "set_var",
              "scope": "entity",
              "entity_id": "self",
              "name": "choice_text_x",
              "value": "$project.dialogue.choice_box.text_x"
            },
            {
              "type": "set_var",
              "scope": "entity",
              "entity_id": "self",
              "name": "choice_width",
              "value": "$project.dialogue.choice_box.width"
            }
          ],
          "else": [
            {
              "type": "set_var",
              "scope": "entity",
              "entity_id": "self",
              "name": "text_box_x",
              "value": "$project.dialogue.plain_box.x"
            },
            {
              "type": "set_var",
              "scope": "entity",
              "entity_id": "self",
              "name": "text_box_y",
              "value": "$project.dialogue.plain_box.y"
            },
            {
              "type": "set_var",
              "scope": "entity",
              "entity_id": "self",
              "name": "text_box_width",
              "value": "$project.dialogue.plain_box.width"
            },
            {
              "type": "set_var",
              "scope": "entity",
              "entity_id": "self",
              "name": "choice_marker_x",
              "value": "$project.dialogue.plain_choice_box.marker_x"
            },
            {
              "type": "set_var",
              "scope": "entity",
              "entity_id": "self",
              "name": "choice_text_x",
              "value": "$project.dialogue.plain_choice_box.text_x"
            },
            {
              "type": "set_var",
              "scope": "entity",
              "entity_id": "self",
              "name": "choice_width",
              "value": "$project.dialogue.plain_choice_box.width"
            }
          ]
        }
      ]
    },
    "_present_frame": {
      "enabled": true,
      "commands": [
        {
          "type": "remove_screen_element",
          "element_id": "dialogue_text"
        },
        {
          "type": "run_event",
          "entity_id": "self",
          "event_id": "_clear_choices"
        },
        {
          "type": "show_screen_image",
          "element_id": "dialogue_panel",
          "path": "$project.dialogue.panel_path",
          "x": 0,
          "y": "$project.display.internal_height",
          "anchor": "bottomleft",
          "layer": 100
        },
        {
          "type": "set_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "portrait_frame_width",
          "value": "$portrait_frame_width"
        },
        {
          "type": "set_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "portrait_frame_height",
          "value": "$portrait_frame_height"
        },
        {
          "type": "set_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "portrait_frame",
          "value": "$portrait_frame"
        },
        {
          "type": "check_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "portrait_path",
          "op": "neq",
          "value": "",
          "then": [
            {
              "type": "show_screen_image",
              "element_id": "dialogue_portrait",
              "path": "$self.portrait_path",
              "x": "$project.dialogue.portrait_position.x",
              "y": "$project.dialogue.portrait_position.y",
              "anchor": "topleft",
              "layer": 101,
              "frame_width": "$self.portrait_frame_width",
              "frame_height": "$self.portrait_frame_height",
              "frame": "$self.portrait_frame"
            }
          ],
          "else": [
            {
              "type": "remove_screen_element",
              "element_id": "dialogue_portrait"
            }
          ]
        }
      ]
    },
    "_open_pages_source": {
      "enabled": true,
      "commands": [
        {
          "type": "run_event",
          "entity_id": "self",
          "event_id": "_clear_choices"
        },
        {
          "type": "set_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "mode",
          "value": "pages"
        },
        {
          "type": "set_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "after_pages_event_id",
          "value": "$after_pages_event_id"
        },
        {
          "type": "prepare_text_session",
          "entity_id": "self",
          "session_id": "main",
          "dialogue_id": "$dialogue_id",
          "text": "$text",
          "pages": "$pages",
          "max_width": "$self.text_box_width",
          "max_lines": "$project.dialogue.max_lines"
        },
        {
          "type": "run_event",
          "entity_id": "self",
          "event_id": "_render_page"
        }
      ]
    },
    "_render_page": {
      "enabled": true,
      "commands": [
        {
          "type": "read_text_session",
          "entity_id": "self",
          "session_id": "main",
          "scope": "entity",
          "store_entity_id": "self",
          "store_text_var": "page_text",
          "store_has_more_var": "page_has_more"
        },
        {
          "type": "show_screen_text",
          "element_id": "dialogue_text",
          "text": "$self.page_text",
          "x": "$self.text_box_x",
          "y": "$self.text_box_y",
          "layer": 101,
          "max_width": "$self.text_box_width"
        }
      ]
    },
    "_interact_pages": {
      "enabled": true,
      "commands": [
        {
          "type": "check_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "page_has_more",
          "op": "eq",
          "value": true,
          "then": [
            {
              "type": "advance_text_session",
              "entity_id": "self",
              "session_id": "main"
            },
            {
              "type": "run_event",
              "entity_id": "self",
              "event_id": "_render_page"
            }
          ],
          "else": [
            {
              "type": "run_event",
              "entity_id": "self",
              "event_id": "$self.after_pages_event_id"
            }
          ]
        }
      ]
    },
    "_finish_dialogue": {
      "enabled": true,
      "commands": [
        {
          "type": "set_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "finish_commands_snapshot",
          "value": "$self.on_finish_commands"
        },
        {
          "type": "run_event",
          "entity_id": "self",
          "event_id": "_close_without_finish"
        },
        {
          "type": "run_commands",
          "commands": "$self.finish_commands_snapshot",
          "source_entity_id": "$self.command_source_entity_id"
        }
      ]
    },
    "_close_without_finish": {
      "enabled": true,
      "commands": [
        {
          "type": "remove_screen_element",
          "element_id": "dialogue_text"
        },
        {
          "type": "remove_screen_element",
          "element_id": "dialogue_panel"
        },
        {
          "type": "remove_screen_element",
          "element_id": "dialogue_portrait"
        },
        {
          "type": "run_event",
          "entity_id": "self",
          "event_id": "_clear_choices"
        },
        {
          "type": "set_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "mode",
          "value": ""
        },
        {
          "type": "set_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "after_pages_event_id",
          "value": "close"
        },
        {
          "type": "set_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "page_has_more",
          "value": false
        },
        {
          "type": "set_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "choice_count",
          "value": 0
        },
        {
          "type": "set_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "choice_selected_index",
          "value": 0
        },
        {
          "type": "set_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "choice_scroll_offset",
          "value": 0
        },
        {
          "type": "set_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "choice_bottom_visible_index",
          "value": 0
        },
        {
          "type": "set_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "selected_visible_slot",
          "value": 0
        },
        {
          "type": "set_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "temp_last_index",
          "value": 0
        },
        {
          "type": "set_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "prompt_dialogue_id",
          "value": ""
        },
        {
          "type": "set_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "prompt_text",
          "value": ""
        },
        {
          "type": "set_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "prompt_pages",
          "value": []
        },
        {
          "type": "set_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "prompt_page_count",
          "value": 0
        },
        {
          "type": "set_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "menu_choices",
          "value": []
        },
        {
          "type": "set_var",
          "scope": "entity",
          "entity_id": "self",
          "name": "on_finish_commands",
          "value": []
        },
        {
          "type": "pop_active_entity"
        }
      ]
    },
    "_clear_choices": {
      "enabled": true,
      "commands": [
        {
          "type": "remove_screen_element",
          "element_id": "dialogue_choice_marker_0"
        },
        {
          "type": "remove_screen_element",
          "element_id": "dialogue_choice_marker_1"
        },
        {
          "type": "remove_screen_element",
          "element_id": "dialogue_choice_marker_2"
        },
        {
          "type": "remove_screen_element",
          "element_id": "dialogue_choice_0"
        },
        {
          "type": "remove_screen_element",
          "element_id": "dialogue_choice_1"
        },
        {
          "type": "remove_screen_element",
          "element_id": "dialogue_choice_2"
        },
        {
          "type": "remove_screen_element",
          "element_id": "dialogue_more_top"
        },
        {
          "type": "remove_screen_element",
          "element_id": "dialogue_more_bottom"
        }
      ]
    },
    "_move_choice_up": {
      "enabled": true,
      "commands": [
        {
