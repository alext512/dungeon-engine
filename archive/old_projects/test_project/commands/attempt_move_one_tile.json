{
  "params": [
    "direction",
    "flip_x",
    "push_event_id",
    "phase_a_frames",
    "phase_b_frames",
    "idle_frame",
    "frames_per_sprite_change",
    "frames_needed"
  ],
  "commands": [
    {
      "type": "set_entity_var",
      "entity_id": "$self_id",
      "name": "move_self_position",
      "value": {
        "$entity_ref": {
          "entity_id": "$self_id",
          "select": {
            "fields": [
              "grid_x",
              "grid_y",
              "pixel_x",
              "pixel_y"
            ]
          }
        }
      }
    },
    {
      "type": "set_entity_var",
      "entity_id": "$self_id",
      "name": "move_current_pixel_x",
      "value": "$self.move_self_position.pixel_x"
    },
    {
      "type": "set_entity_var",
      "entity_id": "$self_id",
      "name": "move_current_pixel_y",
      "value": "$self.move_self_position.pixel_y"
    },
    {
      "type": "set_entity_var",
      "entity_id": "$self_id",
      "name": "move_expected_pixel_x",
      "value": {
        "$product": [
          "$self.move_self_position.grid_x",
          "$area.tile_size"
        ]
      }
    },
    {
      "type": "set_entity_var",
      "entity_id": "$self_id",
      "name": "move_expected_pixel_y",
      "value": {
        "$product": [
          "$self.move_self_position.grid_y",
          "$area.tile_size"
        ]
      }
    },
    {
      "type": "set_entity_var",
      "entity_id": "$self_id",
      "name": "move_offset",
      "value": {
        "$collection_item": {
          "value": {
            "up": {
              "x": 0,
              "y": -1
            },
            "down": {
              "x": 0,
              "y": 1
            },
            "left": {
              "x": -1,
              "y": 0
            },
            "right": {
              "x": 1,
              "y": 0
            }
          },
          "key": "$direction",
          "default": {
            "x": 0,
            "y": 0
          }
        }
      }
    },
    {
      "type": "set_entity_var",
      "entity_id": "$self_id",
      "name": "move_target_x",
      "value": {
        "$sum": [
          "$self.move_self_position.grid_x",
          "$self.move_offset.x"
        ]
      }
    },
    {
      "type": "set_entity_var",
      "entity_id": "$self_id",
      "name": "move_target_y",
      "value": {
        "$sum": [
          "$self.move_self_position.grid_y",
          "$self.move_offset.y"
        ]
      }
    },
    {
      "type": "set_entity_var",
      "entity_id": "$self_id",
      "name": "move_target_cell_flags",
      "value": {
        "$cell_flags_at": {
          "x": "$self.move_target_x",
          "y": "$self.move_target_y",
          "default": {
            "walkable": false
          }
        }
      }
    },
    {
      "type": "set_entity_var",
      "entity_id": "$self_id",
      "name": "move_target_walkable",
      "value": {
        "$collection_item": {
          "value": "$self.move_target_cell_flags",
          "key": "walkable",
          "default": false
        }
      }
    },
    {
      "type": "set_entity_var",
      "entity_id": "$self_id",
      "name": "move_target_entities",
      "value": {
        "$entities_at": {
          "x": "$self.move_target_x",
          "y": "$self.move_target_y",
          "exclude_entity_id": "$self_id",
          "include_hidden": true,
          "select": {
            "fields": [
              "entity_id"
            ],
            "variables": [
              "blocks_movement",
              "pushable"
            ]
          }
        }
      }
    },
    {
      "type": "set_entity_var",
      "entity_id": "$self_id",
      "name": "move_blocking_entity",
      "value": {
        "$find_in_collection": {
          "value": "$self.move_target_entities",
          "field": "variables.blocks_movement",
          "op": "eq",
          "match": true,
          "default": null
        }
      }
    },
    {
      "type": "if",
      "op": "eq",
      "then": [
        {
          "type": "if",
          "op": "eq",
          "then": [
            {
              "type": "set_visual_flip_x",
              "entity_id": "$self_id",
              "flip_x": "$flip_x"
            },
            {
              "entity_id": "$self_id",
              "name": "direction",
              "type": "set_entity_var",
              "value": "$direction"
            },
            {
              "type": "if",
              "op": "eq",
              "then": [
                {
                  "type": "spawn_flow",
                  "commands": [
                    {
                      "type": "run_entity_command",
                      "entity_id": "self",
                      "command_id": "play_bump_sound"
                    }
                  ]
                },
                {
                  "type": "set_visual_frame",
                  "entity_id": "$self_id",
                  "frame": "$idle_frame"
                }
              ],
              "else": [
                {
                  "type": "if",
                  "op": "eq",
                  "then": [
                    {
                      "type": "run_project_command",
                      "command_id": "commands/walk_one_tile",
                      "offset_x": "$self.move_offset.x",
                      "offset_y": "$self.move_offset.y",
                      "phase_a_frames": "$phase_a_frames",
                      "phase_b_frames": "$phase_b_frames",
                      "idle_frame": "$idle_frame",
                      "frames_per_sprite_change": "$frames_per_sprite_change",
                      "frames_needed": "$frames_needed"
                    }
                  ],
                  "else": [
                    {
                      "type": "set_entity_var",
                      "entity_id": "$self_id",
                      "name": "move_blocking_entity_pushable",
                      "value": {
                        "$collection_item": {
                          "value": "$self.move_blocking_entity.variables",
                          "key": "pushable",
                          "default": false
                        }
                      }
                    },
                    {
                      "type": "if",
                      "op": "eq",
                      "then": [
                        {
                          "type": "run_entity_command",
                          "entity_id": "$self.move_blocking_entity.entity_id",
                          "command_id": "$push_event_id",
                          "entity_refs": {
                            "instigator": "$self_id"
                          }
                        },
                        {
                          "type": "set_entity_var",
                          "entity_id": "$self_id",
                          "name": "move_target_entities",
                          "value": {
                            "$entities_at": {
                              "x": "$self.move_target_x",
                              "y": "$self.move_target_y",
                              "exclude_entity_id": "$self_id",
                              "include_hidden": true,
                              "select": {
                                "fields": [
                                  "entity_id"
                                ],
                                "variables": [
                                  "blocks_movement",
                                  "pushable"
                                ]
                              }
                            }
                          }
                        },
                        {
                          "type": "set_entity_var",
                          "entity_id": "$self_id",
                          "name": "move_blocking_entity",
                          "value": {
                            "$find_in_collection": {
                              "value": "$self.move_target_entities",
                              "field": "variables.blocks_movement",
                              "op": "eq",
                              "match": true,
                              "default": null
                            }
                          }
                        },
                        {
                          "type": "if",
                          "op": "eq",
                          "then": [
                            {
                              "type": "run_project_command",
                              "command_id": "commands/walk_one_tile",
                              "offset_x": "$self.move_offset.x",
                              "offset_y": "$self.move_offset.y",
                              "phase_a_frames": "$phase_a_frames",
                              "phase_b_frames": "$phase_b_frames",
                              "idle_frame": "$idle_frame",
                              "frames_per_sprite_change": "$frames_per_sprite_change",
                              "frames_needed": "$frames_needed"
                            }
                          ],
                          "else": [
                            {
                              "type": "spawn_flow",
                              "commands": [
                                {
                                  "type": "run_entity_command",
                                  "entity_id": "self",
                                  "command_id": "play_bump_sound"
                                }
                              ]
                            },
                            {
                              "type": "set_visual_frame",
                              "entity_id": "$self_id",
                              "frame": "$idle_frame"
                            }
                          ],
                          "left": {
                            "$entity_var": {
                              "entity_id": "$self_id",
                              "name": "move_blocking_entity"
                            }
                          },
                          "right": null
                        }
                      ],
                      "else": [
                        {
                          "type": "spawn_flow",
                          "commands": [
                            {
                              "type": "run_entity_command",
                              "entity_id": "self",
                              "command_id": "play_bump_sound"
                            }
                          ]
                        },
                        {
                          "type": "set_visual_frame",
                          "entity_id": "$self_id",
                          "frame": "$idle_frame"
                        }
                      ],
                      "left": {
                        "$entity_var": {
                          "entity_id": "$self_id",
                          "name": "move_blocking_entity_pushable"
                        }
                      },
                      "right": true
                    }
                  ],
                  "left": {
                    "$entity_var": {
                      "entity_id": "$self_id",
                      "name": "move_blocking_entity"
                    }
                  },
                  "right": null
                }
              ],
              "left": {
                "$entity_var": {
                  "entity_id": "$self_id",
                  "name": "move_target_walkable"
                }
              },
              "right": false
            }
          ],
          "left": {
            "$entity_var": {
              "entity_id": "$self_id",
              "name": "move_current_pixel_y"
            }
          },
          "right": "$self.move_expected_pixel_y"
        }
      ],
      "left": {
        "$entity_var": {
          "entity_id": "$self_id",
          "name": "move_current_pixel_x"
        }
      },
      "right": "$self.move_expected_pixel_x"
    }
  ]
}
