{
  "kind": "hole",
  "variables": {
    "blocks_movement": true,
    "filled": false,
    "hole_shape": "$hole_shape",
    "target_gate_id": "$target_gate_id",
    "target_index": "$target_index",
    "target_amount": "$target_amount"
  },
  "visuals": [
    {
      "id": "main",
      "path": "$sprite_path",
      "frame_width": 16,
      "frame_height": 16,
      "frames": [
        0
      ]
    }
  ],
  "entity_commands": {
    "accept_actor": {
      "enabled": true,
      "commands": [
        {
          "type": "if",
          "op": "eq",
          "then": [
            {
              "type": "if",
              "op": "eq",
              "then": [
                {
                  "type": "set_entity_var",
                  "entity_id": "$self_id",
                  "name": "filled",
                  "value": true
                },
                {
                  "type": "set_entity_var",
                  "entity_id": "$self_id",
                  "name": "blocks_movement",
                  "value": false
                },
                {
                  "type": "set_entity_field",
                  "entity_id": "$ref_ids.instigator",
                  "field_name": "present",
                  "value": false
                },
                {
                  "type": "set_entity_field",
                  "entity_id": "$ref_ids.instigator",
                  "field_name": "visible",
                  "value": false
                },
                {
                  "type": "set_entity_field",
                  "entity_id": "$ref_ids.instigator",
                  "field_name": "entity_commands_enabled",
                  "value": false
                },
                {
                  "type": "set_entity_var",
                  "entity_id": "$ref_ids.instigator",
                  "name": "blocks_movement",
                  "value": false
                },
                {
                  "type": "if",
                  "op": "neq",
                  "then": [
                    {
                      "type": "run_entity_command",
                      "entity_id": "$self.target_gate_id",
                      "command_id": "add_input_value",
                      "index": "$self.target_index",
                      "amount": "$self.target_amount"
                    }
                  ],
                  "left": {
                    "$entity_var": {
                      "entity_id": "$self_id",
                      "name": "target_gate_id"
                    }
                  },
                  "right": ""
                }
              ],
              "left": {
                "$entity_var": {
                  "entity_id": "$ref_ids.instigator",
                  "name": "shape"
                }
              },
              "right": "$self.hole_shape"
            }
          ],
          "left": {
            "$entity_var": {
              "entity_id": "$self_id",
              "name": "filled"
            }
          },
          "right": false
        }
      ]
    }
  },
  "render_order": 0
}
