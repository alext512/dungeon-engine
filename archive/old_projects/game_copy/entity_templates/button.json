{
  "kind": "button",
  "tags": [
    "enter_trigger",
    "leave_trigger"
  ],
  "variables": {
    "blocks_movement": false,
    "pressed": false,
    "single_use": "$single_use",
    "target_gate_id": "$target_gate_id",
    "target_index": "$target_index",
    "press_value": "$press_value",
    "release_value": "$release_value"
  },
  "visuals": [
    {
      "id": "main",
      "path": "assets/original/button.png",
      "frame_width": 16,
      "frame_height": 16,
      "frames": [
        0
      ]
    }
  ],
  "entity_commands": {
    "entered_by": {
      "enabled": true,
      "commands": [
        {
          "type": "if",
          "op": "eq",
          "then": [
            {
              "type": "set_entity_var",
              "entity_id": "$self_id",
              "name": "pressed",
              "value": true
            },
            {
              "type": "set_visual_frame",
              "entity_id": "$self_id",
              "frame": 1
            },
            {
              "type": "if",
              "op": "neq",
              "then": [
                {
                  "type": "run_entity_command",
                  "entity_id": "$self.target_gate_id",
                  "command_id": "set_input_value",
                  "index": "$self.target_index",
                  "value": "$self.press_value"
                }
              ],
              "left": {
                "$entity_var": {
                  "entity_id": "$self_id",
                  "name": "target_gate_id"
                }
              },
              "right": ""
            },
            {
              "type": "if",
              "op": "eq",
              "then": [
                {
                  "type": "set_entity_field",
                  "entity_id": "$self_id",
                  "field_name": "entity_commands_enabled",
                  "value": false
                }
              ],
              "left": {
                "$entity_var": {
                  "entity_id": "$self_id",
                  "name": "single_use"
                }
              },
              "right": true
            }
          ],
          "left": {
            "$entity_var": {
              "entity_id": "$self_id",
              "name": "pressed"
            }
          },
          "right": false
        }
      ]
    },
    "left_by": {
      "enabled": true,
      "commands": [
        {
          "type": "if",
          "op": "eq",
          "then": [
            {
              "type": "if",
              "op": "eq",
              "then": [
                {
                  "type": "set_entity_var",
                  "entity_id": "$self_id",
                  "name": "pressed",
                  "value": false
                },
                {
                  "type": "set_visual_frame",
                  "entity_id": "$self_id",
                  "frame": 0
                },
                {
                  "type": "if",
                  "op": "neq",
                  "then": [
                    {
                      "type": "run_entity_command",
                      "entity_id": "$self.target_gate_id",
                      "command_id": "set_input_value",
                      "index": "$self.target_index",
                      "value": "$self.release_value"
                    }
                  ],
                  "left": {
                    "$entity_var": {
                      "entity_id": "$self_id",
                      "name": "target_gate_id"
                    }
                  },
                  "right": ""
                }
              ],
              "left": {
                "$entity_var": {
                  "entity_id": "$self_id",
                  "name": "pressed"
                }
              },
              "right": true
            }
          ],
          "left": {
            "$entity_var": {
              "entity_id": "$self_id",
              "name": "single_use"
            }
          },
          "right": false
        }
      ]
    }
  },
  "render_order": 0
}
