{
  "kind": "gate",
  "variables": {
    "blocks_movement": true,
    "open": false,
    "input_value_0": 0,
    "input_value_1": 0,
    "input_value_2": 0,
    "correct_value_0": "$correct_value_0",
    "correct_value_1": "$correct_value_1",
    "correct_value_2": "$correct_value_2",
    "pending_index": 0,
    "pending_value": 0,
    "pending_amount": 0
  },
  "visuals": [
    {
      "id": "main",
      "path": "assets/original/Iron_Gate.png",
      "frame_width": 16,
      "frame_height": 16,
      "frames": [
        0
      ]
    }
  ],
  "entity_commands": {
    "set_input_value": {
      "enabled": true,
      "commands": [
        {
          "type": "set_entity_var",
          "entity_id": "$self_id",
          "name": "pending_index",
          "value": "$index"
        },
        {
          "type": "set_entity_var",
          "entity_id": "$self_id",
          "name": "pending_value",
          "value": "$value"
        },
        {
          "type": "if",
          "op": "eq",
          "then": [
            {
              "type": "set_entity_var",
              "entity_id": "$self_id",
              "name": "input_value_0",
              "value": "$self.pending_value"
            }
          ],
          "else": [
            {
              "type": "if",
              "op": "eq",
              "then": [
                {
                  "type": "set_entity_var",
                  "entity_id": "$self_id",
                  "name": "input_value_1",
                  "value": "$self.pending_value"
                }
              ],
              "else": [
                {
                  "type": "set_entity_var",
                  "entity_id": "$self_id",
                  "name": "input_value_2",
                  "value": "$self.pending_value"
                }
              ],
              "left": {
                "$entity_var": {
                  "entity_id": "$self_id",
                  "name": "pending_index"
                }
              },
              "right": 1
            }
          ],
          "left": {
            "$entity_var": {
              "entity_id": "$self_id",
              "name": "pending_index"
            }
          },
          "right": 0
        },
        {
          "type": "run_entity_command",
          "entity_id": "$self_id",
          "command_id": "recalc"
        }
      ]
    },
    "add_input_value": {
      "enabled": true,
      "commands": [
        {
          "type": "set_entity_var",
          "entity_id": "$self_id",
          "name": "pending_index",
          "value": "$index"
        },
        {
          "type": "set_entity_var",
          "entity_id": "$self_id",
          "name": "pending_amount",
          "value": "$amount"
        },
        {
          "type": "if",
          "op": "eq",
          "then": [
            {
              "type": "add_entity_var",
              "entity_id": "$self_id",
              "name": "input_value_0",
              "amount": "$self.pending_amount"
            }
          ],
          "else": [
            {
              "type": "if",
              "op": "eq",
              "then": [
                {
                  "type": "add_entity_var",
                  "entity_id": "$self_id",
                  "name": "input_value_1",
                  "amount": "$self.pending_amount"
                }
              ],
              "else": [
                {
                  "type": "add_entity_var",
                  "entity_id": "$self_id",
                  "name": "input_value_2",
                  "amount": "$self.pending_amount"
                }
              ],
              "left": {
                "$entity_var": {
                  "entity_id": "$self_id",
                  "name": "pending_index"
                }
              },
              "right": 1
            }
          ],
          "left": {
            "$entity_var": {
              "entity_id": "$self_id",
              "name": "pending_index"
            }
          },
          "right": 0
        },
        {
          "type": "run_entity_command",
          "entity_id": "$self_id",
          "command_id": "recalc"
        }
      ]
    },
    "recalc": {
      "enabled": true,
      "commands": [
        {
          "type": "if",
          "op": "eq",
          "then": [
            {
              "type": "if",
              "op": "eq",
              "then": [
                {
                  "type": "if",
                  "op": "eq",
                  "then": [
                    {
                      "type": "run_entity_command",
                      "entity_id": "$self_id",
                      "command_id": "open_gate"
                    }
                  ],
                  "else": [
                    {
                      "type": "run_entity_command",
                      "entity_id": "$self_id",
                      "command_id": "close_gate"
                    }
                  ],
                  "left": {
                    "$entity_var": {
                      "entity_id": "$self_id",
                      "name": "input_value_2"
                    }
                  },
                  "right": "$self.correct_value_2"
                }
              ],
              "else": [
                {
                  "type": "run_entity_command",
                  "entity_id": "$self_id",
                  "command_id": "close_gate"
                }
              ],
              "left": {
                "$entity_var": {
                  "entity_id": "$self_id",
                  "name": "input_value_1"
                }
              },
              "right": "$self.correct_value_1"
            }
          ],
          "else": [
            {
              "type": "run_entity_command",
              "entity_id": "$self_id",
              "command_id": "close_gate"
            }
          ],
          "left": {
            "$entity_var": {
              "entity_id": "$self_id",
              "name": "input_value_0"
            }
          },
          "right": "$self.correct_value_0"
        }
      ]
    },
    "open_gate": {
      "enabled": true,
      "commands": [
        {
          "type": "if",
          "op": "eq",
          "then": [
            {
              "type": "set_entity_var",
              "entity_id": "$self_id",
              "name": "open",
              "value": true
            },
            {
              "type": "set_entity_var",
              "entity_id": "$self_id",
              "name": "blocks_movement",
              "value": false
            },
            {
              "type": "set_entity_field",
              "entity_id": "$self_id",
              "field_name": "visible",
              "value": true
            },
            {
              "type": "set_visual_frame",
              "entity_id": "$self_id",
              "frame": 0
            },
            {
              "type": "play_animation",
              "entity_id": "$self_id",
              "frame_sequence": [
                1,
                2,
                3,
                4,
                5
              ],
              "frames_per_sprite_change": 4,
              "hold_last_frame": true,
              "wait": true
            },
            {
              "type": "set_entity_field",
              "entity_id": "$self_id",
              "field_name": "visible",
              "value": false
            }
          ],
          "left": {
            "$entity_var": {
              "entity_id": "$self_id",
              "name": "open"
            }
          },
          "right": false
        }
      ]
    },
    "close_gate": {
      "enabled": true,
      "commands": [
        {
          "type": "if",
          "op": "eq",
          "then": [
            {
              "type": "set_entity_var",
              "entity_id": "$self_id",
              "name": "open",
              "value": false
            },
            {
              "type": "set_entity_var",
              "entity_id": "$self_id",
              "name": "blocks_movement",
              "value": true
            },
            {
              "type": "set_entity_field",
              "entity_id": "$self_id",
              "field_name": "visible",
              "value": true
            },
            {
              "type": "set_visual_frame",
              "entity_id": "$self_id",
              "frame": 5
            },
            {
              "type": "play_animation",
              "entity_id": "$self_id",
              "frame_sequence": [
                4,
                3,
                2,
                1,
                0
              ],
              "frames_per_sprite_change": 4,
              "hold_last_frame": true,
              "wait": true
            }
          ],
          "left": {
            "$entity_var": {
              "entity_id": "$self_id",
              "name": "open"
            }
          },
          "right": true
        }
      ]
    }
  },
  "render_order": 10
}
