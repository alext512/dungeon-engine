{
  "params": [
    "level_number"
  ],
  "commands": [
    {
      "type": "if",
      "op": "lt",
      "then": [
        {
          "type": "set_entity_var",
          "entity_id": "progress_controller",
          "name": "levels_completed",
          "value": "$level_number",
          "persistent": true
        }
      ],
      "left": {
        "$entity_var": {
          "entity_id": "progress_controller",
          "name": "levels_completed"
        }
      },
      "right": "$level_number"
    }
  ]
}
