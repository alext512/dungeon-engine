{
  "params": [],
  "commands": [
    {
      "type": "if",
      "op": "eq",
      "then": [
        {
          "type": "add_entity_var",
          "entity_id": "$self_id",
          "name": "dialogue_text_line_offset",
          "amount": "$self.dialogue_max_lines"
        },
        {
          "type": "run_project_command",
          "command_id": "commands/dialogue/load_and_render_segment"
        }
      ],
      "else": [
        {
          "type": "set_entity_var",
          "entity_id": "$self_id",
          "name": "dialogue_next_source_page_index",
          "value": "$self.dialogue_source_page_index"
        },
        {
          "type": "add_entity_var",
          "entity_id": "$self_id",
          "name": "dialogue_next_source_page_index",
          "amount": 1
        },
        {
          "type": "if",
          "op": "lt",
          "then": [
            {
              "type": "set_entity_var",
              "entity_id": "$self_id",
              "name": "dialogue_source_page_index",
              "value": "$self.dialogue_next_source_page_index"
            },
            {
              "type": "set_entity_var",
              "entity_id": "$self_id",
              "name": "dialogue_text_line_offset",
              "value": 0
            },
            {
              "type": "run_project_command",
              "command_id": "commands/dialogue/load_and_render_segment"
            }
          ],
          "else": [
            {
              "type": "run_project_command",
              "command_id": "commands/dialogue/finish_segment"
            }
          ],
          "left": {
            "$entity_var": {
              "entity_id": "$self_id",
              "name": "dialogue_next_source_page_index"
            }
          },
          "right": "$self.dialogue_current_source_page_count"
        }
      ],
      "left": {
        "$entity_var": {
          "entity_id": "$self_id",
          "name": "dialogue_current_has_more_text"
        }
      },
      "right": true
    }
  ]
}
