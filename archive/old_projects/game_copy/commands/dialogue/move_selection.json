{
  "params": [
    "delta"
  ],
  "commands": [
    {
      "type": "if",
      "op": "eq",
      "then": [
        {
          "type": "if",
          "op": "gt",
          "then": [
            {
              "type": "set_entity_var",
              "entity_id": "$self_id",
              "name": "dialogue_choice_index",
              "value": {
                "$wrap_index": {
                  "value": {
                    "$sum": [
                      "$self.dialogue_choice_index",
                      "$delta"
                    ]
                  },
                  "count": "$self.dialogue_current_option_count",
                  "default": 0
                }
              }
            },
            {
              "type": "if",
              "op": "lt",
              "then": [
                {
                  "type": "set_entity_var",
                  "entity_id": "$self_id",
                  "name": "dialogue_choice_scroll_offset",
                  "value": "$self.dialogue_choice_index"
                }
              ],
              "else": [
                {
                  "type": "if",
                  "op": "gte",
                  "then": [
                    {
                      "type": "set_entity_var",
                      "entity_id": "$self_id",
                      "name": "dialogue_choice_scroll_offset",
                      "value": {
                        "$sum": [
                          "$self.dialogue_choice_index",
                          {
                            "$product": [
                              -1,
                              "$self.layout.choice.visible_rows"
                            ]
                          },
                          1
                        ]
                      }
                    }
                  ],
                  "left": {
                    "$entity_var": {
                      "entity_id": "$self_id",
                      "name": "dialogue_choice_index"
                    }
                  },
                  "right": {
                    "$sum": [
                      "$self.dialogue_choice_scroll_offset",
                      "$self.layout.choice.visible_rows"
                    ]
                  }
                }
              ],
              "left": {
                "$entity_var": {
                  "entity_id": "$self_id",
                  "name": "dialogue_choice_index"
                }
              },
              "right": "$self.dialogue_choice_scroll_offset"
            },
            {
              "type": "run_project_command",
              "command_id": "commands/dialogue/render_choice"
            }
          ],
          "left": {
            "$entity_var": {
              "entity_id": "$self_id",
              "name": "dialogue_current_option_count"
            }
          },
          "right": 0
        }
      ],
      "left": {
        "$entity_var": {
          "entity_id": "$self_id",
          "name": "dialogue_phase"
        }
      },
      "right": "choice"
    }
  ]
}
