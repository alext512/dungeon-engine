{
  "params": [],
  "commands": [
    {
      "type": "set_entity_var",
      "name": "dialogue_current_selected_option",
      "entity_id": "$self_id",
      "value": {
        "$collection_item": {
          "value": "$self.dialogue_current_segment_options",
          "index": "$self.dialogue_choice_index",
          "default": {}
        }
      }
    },
    {
      "type": "set_entity_var",
      "name": "dialogue_current_selected_option_id",
      "entity_id": "$self_id",
      "value": {
        "$collection_item": {
          "value": "$self.dialogue_current_selected_option",
          "key": "option_id",
          "default": ""
        }
      }
    },
    {
      "type": "set_entity_var_length",
      "name": "dialogue_current_option_commands_by_id_count",
      "entity_id": "$self_id",
      "value": "$self.dialogue_current_option_commands_by_id"
    },
    {
      "type": "if",
      "op": "neq",
      "then": [
        {
          "type": "if",
          "op": "gt",
          "then": [
            {
              "type": "set_entity_var",
              "name": "dialogue_current_selected_option_commands",
              "entity_id": "$self_id",
              "value": {
                "$collection_item": {
                  "value": "$self.dialogue_current_option_commands_by_id",
                  "key": "$self.dialogue_current_selected_option_id",
                  "default": []
                }
              }
            }
          ],
          "else": [
            {
              "type": "set_entity_var",
              "name": "dialogue_current_selected_option_commands",
              "entity_id": "$self_id",
              "value": {
                "$collection_item": {
                  "value": "$self.dialogue_current_option_commands",
                  "index": "$self.dialogue_choice_index",
                  "default": []
                }
              }
            }
          ],
          "left": {
            "$entity_var": {
              "entity_id": "$self_id",
              "name": "dialogue_current_option_commands_by_id_count"
            }
          },
          "right": 0
        }
      ],
      "else": [
        {
          "type": "set_entity_var",
          "name": "dialogue_current_selected_option_commands",
          "entity_id": "$self_id",
          "value": {
            "$collection_item": {
              "value": "$self.dialogue_current_option_commands",
              "index": "$self.dialogue_choice_index",
              "default": []
            }
          }
        }
      ],
      "left": {
        "$entity_var": {
          "entity_id": "$self_id",
          "name": "dialogue_current_selected_option_id"
        }
      },
      "right": ""
    },
    {
      "type": "set_entity_var",
      "entity_id": "$self_id",
      "name": "dialogue_confirm_revision_snapshot",
      "value": "$self.dialogue_revision"
    },
    {
      "type": "run_commands",
      "commands": "$self.dialogue_current_selected_option_commands",
      "entity_refs": {
        "instigator": "$self.dialogue_actor_id",
        "caller": "$self.dialogue_caller_id"
      }
    },
    {
      "type": "if",
      "op": "eq",
      "then": [
        {
          "type": "if",
          "op": "eq",
          "then": [
            {
              "type": "run_project_command",
              "command_id": "commands/dialogue/finish_segment"
            }
          ],
          "left": {
            "$entity_var": {
              "entity_id": "$self_id",
              "name": "dialogue_revision"
            }
          },
          "right": "$self.dialogue_confirm_revision_snapshot"
        }
      ],
      "left": {
        "$entity_var": {
          "entity_id": "$self_id",
          "name": "dialogue_open"
        }
      },
      "right": true
    }
  ]
}
